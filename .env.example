# ── LLM Provider (OpenCode Zen) ──
# Modelos disponibles via Zen: https://opencode.ai/docs/zen/
# deepseek-v4-flash-free, deepseek-v4-flash, deepseek-v4-pro, etc.
SOCIAL_AGENT_LLM_PROVIDER=openai/deepseek-v4-flash-free
SOCIAL_AGENT_LLM_API_KEY=sk-...  # Tu API key de https://opencode.ai/auth
SOCIAL_AGENT_LLM_BASE_URL=https://opencode.ai/zen/v1

# ── LLM alternativos (comentar los de arriba y descomentar estos) ──
# OpenAI Directo
# SOCIAL_AGENT_LLM_PROVIDER=openai/gpt-4o
# SOCIAL_AGENT_LLM_API_KEY=sk-...
# Ollama (local)
# SOCIAL_AGENT_LLM_PROVIDER=ollama/llama3
# SOCIAL_AGENT_LLM_BASE_URL=http://localhost:11434

# ── Redes sociales ──
# Twitter/X API v2 Bearer Token
SOCIAL_AGENT_TWITTER_BEARER_TOKEN=
# LinkedIn OAuth Access Token
SOCIAL_AGENT_LINKEDIN_ACCESS_TOKEN=
