# ── LLM Provider (OpenCode Zen) ──
# Modelos disponibles via Zen: https://opencode.ai/docs/zen/
# deepseek-v4-flash-free, deepseek-v4-flash, deepseek-v4-pro, etc.
SOCIAL_AGENT_LLM_PROVIDER=openai/deepseek-v4-flash-free
SOCIAL_AGENT_LLM_API_KEY=sk-...  # Tu API key de https://opencode.ai/auth
SOCIAL_AGENT_LLM_BASE_URL=https://opencode.ai/zen/v1

# ── LLM alternativos (comentar los de arriba y descomentar estos) ──
# OpenAI Directo
# SOCIAL_AGENT_LLM_PROVIDER=openai/gpt-4o
# SOCIAL_AGENT_LLM_API_KEY=sk-...
# Ollama (local)
# SOCIAL_AGENT_LLM_PROVIDER=ollama/llama3
# SOCIAL_AGENT_LLM_BASE_URL=http://localhost:11434

# ── Zona horaria ──
# Usada para interpretar fechas naive (sin offset) al programar publicaciones
# y para mostrar las fechas programadas en `schedule list`.
# Por defecto: Europe/Madrid. Cualquier nombre IANA válido.
# SOCIAL_AGENT_TIMEZONE=Europe/Madrid

# ── Redes sociales ──
# Twitter/X API v2 Bearer Token (para colector)
SOCIAL_AGENT_TWITTER_BEARER_TOKEN=
# Twitter/X API v2 OAuth 1.0a User Context (para publicador)
# Crea un proyecto en https://developer.twitter.com y genera credenciales con permisos de escritura
SOCIAL_AGENT_TWITTER_API_KEY=
SOCIAL_AGENT_TWITTER_API_SECRET=
SOCIAL_AGENT_TWITTER_ACCESS_TOKEN=
SOCIAL_AGENT_TWITTER_ACCESS_TOKEN_SECRET=
# LinkedIn OAuth Client ID y Secret (de tu app en https://developer.linkedin.com)
# Necesarios para generar el token de acceso mediante "social-agent linkedin auth"
SOCIAL_AGENT_LINKEDIN_CLIENT_ID=
SOCIAL_AGENT_LINKEDIN_CLIENT_SECRET=
# LinkedIn Access Token (generado por "social-agent linkedin auth" o manualmente)
# Requiere scope w_member_social para publicar y r_liteprofile+openid para colectar
SOCIAL_AGENT_LINKEDIN_ACCESS_TOKEN=
# LinkedIn author URN (opcional — se resuelve automáticamente si se omite)
# SOCIAL_AGENT_LINKEDIN_AUTHOR_URN=urn:li:person:xxx
