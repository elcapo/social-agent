---
import { iconPath } from "~/scripts/icons";

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 16, class: cls } = Astro.props;
const paths = iconPath(name);
---

{
  paths ? (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
      class={cls}
      set:html={paths}
    />
  ) : null
}
