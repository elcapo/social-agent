---
import Icon from "./Icon.astro";

const current = Astro.url.pathname;

const links = [
  { href: "/", label: "Panel", icon: "layout-dashboard" },
  { href: "/sources", label: "Fuentes", icon: "database" },
  { href: "/seeds", label: "Semillas", icon: "sprout" },
  { href: "/ideas", label: "Ideas", icon: "lightbulb" },
  { href: "/drafts", label: "Borradores", icon: "file-text" },
];

function isActive(href: string): boolean {
  if (href === "/") return current === "/";
  return current === href || current.startsWith(href + "/");
}
---

<div class="navbar bg-base-100 border-b border-base-300 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 w-full flex items-center justify-between gap-2">
    <a
      href="/"
      class="flex items-center gap-2 text-lg font-bold text-primary no-underline shrink-0"
      aria-label="social-agent — inicio"
    >
      <Icon name="share" size={22} />
      <span class="hidden sm:inline">social-agent</span>
    </a>
    <nav class="flex gap-1 overflow-x-auto no-scrollbar" aria-label="Principal">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`btn btn-ghost btn-sm shrink-0 gap-1.5 ${isActive(l.href) ? "btn-active" : ""}`}
            aria-current={isActive(l.href) ? "page" : undefined}
          >
            <Icon name={l.icon} size={16} />
            <span>{l.label}</span>
          </a>
        ))
      }
    </nav>
  </div>
</div>
