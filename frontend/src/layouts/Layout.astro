---
import "../styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — social-agent</title>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:btn focus:btn-primary focus:btn-sm"
    >
      Saltar al contenido
    </a>
    <slot />
  </body>
</html>
