---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Ideas">
  <Nav />
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">Ideas</h1>
      <button class="btn btn-primary" id="btn-generate">Generate idea</button>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>

    <div id="filters-bar" class="flex items-center gap-2 flex-wrap mb-4">
      <details class="dropdown">
        <summary class="btn btn-sm btn-outline">+ Add filter</summary>
        <ul class="dropdown-content menu bg-base-100 border border-base-300 rounded-box z-10 w-44 p-2 shadow-sm">
          <li><button data-add-filter="status">Status</button></li>
          <li><button data-add-filter="keyword">Keyword</button></li>
        </ul>
      </details>
      <div id="active-filters" class="flex items-center gap-2 flex-wrap"></div>
    </div>

    <div id="ideas-list"><span class="loading loading-spinner loading-sm"></span> <span class="text-sm text-base-content/40">Loading...</span></div>
  </main>

  <dialog id="generate-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generate Idea</legend>
        <label class="label">Seed</label>
        <select id="seed-select" class="select w-full">
          <option value="">Loading seeds...</option>
        </select>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="modal-cancel">Cancel</button>
        <button class="btn btn-primary" id="modal-generate">Generate</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="confirm-dialog" class="modal">
    <div class="modal-box">
      <p class="py-2" id="confirm-msg">Are you sure?</p>
      <div class="modal-action">
        <button class="btn" id="confirm-no">Cancel</button>
        <button class="btn btn-primary" id="confirm-yes">Confirm</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    const API = "http://localhost:8000/api";

    const errorEl = document.getElementById("error-msg");

    const ALL_STATUSES = ["pending", "used", "discarded"];
    const STATUS_LABELS = { pending: "warning", used: "success", discarded: "error" };

    const filters = { statuses: [], q: "" };
    const activeTypes = new Set();

    const urlParams = new URLSearchParams(window.location.search);
    const seedStatus = urlParams.get("status");
    if (seedStatus && ALL_STATUSES.includes(seedStatus)) {
      filters.statuses = [seedStatus];
      activeTypes.add("status");
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    async function getErrorMsg(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    function esc(str) {
      if (!str) return "";
      const d = document.createElement("div");
      d.appendChild(document.createTextNode(str));
      return d.innerHTML;
    }

    function askConfirm(msg) {
      return new Promise(resolve => {
        const dialog = document.getElementById("confirm-dialog");
        document.getElementById("confirm-msg").textContent = msg;
        dialog.showModal();
        document.getElementById("confirm-yes").onclick = () => { dialog.close(); resolve(true); };
        document.getElementById("confirm-no").onclick = () => { dialog.close(); resolve(false); };
      });
    }

    async function load() {
      hideError();
      const urlParams = new URLSearchParams();
      (filters.statuses || []).forEach(s => urlParams.append("statuses", s));
      if (filters.q) urlParams.set("q", filters.q);
      const qs = urlParams.toString();
      const res = await fetch(`${API}/ideas${qs ? "?" + qs : ""}`);
      const ideas = await res.json();
      const container = document.getElementById("ideas-list");

      if (!ideas.length) {
        container.innerHTML = '<div class="alert bg-base-200 text-sm">No ideas yet. Click "Generate idea" to create one from a seed.</div>';
        return;
      }

      container.innerHTML = `<ul class="list bg-base-100 border border-base-300 rounded-box divide-y divide-base-200">
        ${ideas.map(idea => `
        <li class="list-row items-center gap-3 py-3">
          <div class="min-w-0 flex-1 max-w-[75%]">
            <div class="font-medium flex items-center gap-1.5">
              ${idea.comment
                ? `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-info shrink-0" title="Tiene comentario para el escritor"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>`
                : ""}
              <span>${esc(idea.title)}</span>
            </div>
            <div class="text-sm text-base-content/50 mt-1 line-clamp-2">${esc(idea.summary || "")}</div>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-base-content/40">seed: ${esc(idea.seed_id || "")}</span>
              ${idea.source_url
                ? `<a href="${esc(idea.source_url)}" target="_blank" rel="noopener noreferrer" class="text-xs text-primary hover:underline truncate max-w-[200px]">${esc(idea.source_url)}</a>`
                : ""}
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0 ml-auto">
            <span class="badge badge-md badge-soft whitespace-nowrap ${idea.status === "pending" ? "badge-warning" : idea.status === "used" ? "badge-success" : "badge-error"}">${idea.status}</span>
            <span class="text-sm text-base-content/40 whitespace-nowrap">${idea.created_at ? new Date(idea.created_at).toLocaleDateString() : "—"}</span>
            <div class="flex gap-1">${idea.status === "pending"
              ? `<button class="btn btn-square btn-ghost btn-sm text-error" data-action="discard" data-id="${idea.id}" aria-label="Discard idea"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`
              : ""}<a href="/ideas/edit?id=${idea.id}" class="btn btn-square btn-ghost btn-sm" aria-label="Edit idea"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></a>${idea.status !== "used"
              ? `<button class="btn btn-square btn-ghost btn-sm text-error" data-action="delete" data-id="${idea.id}" aria-label="Delete idea"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg></button>`
              : ""}</div>
          </div>
        </li>`).join("")}
      </ul>`;
    }

    document.getElementById("ideas-list").addEventListener("click", async (e) => {
      const btn = e.target.closest("[data-action]");
      if (!btn) return;
      hideError();
      const id = btn.dataset.id;

      try {
        switch (btn.dataset.action) {
          case "discard": {
            const res = await fetch(`${API}/ideas/${id}`, {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ status: "discarded" }),
            });
            if (!res.ok) throw new Error(await getErrorMsg(res));
            break;
          }
          case "delete": {
            const ok = await askConfirm("Delete this idea permanently?");
            if (!ok) return;
            const res = await fetch(`${API}/ideas/${id}`, { method: "DELETE" });
            if (!res.ok) throw new Error(await getErrorMsg(res));
            break;
          }
        }
        load();
      } catch (e) {
        showError("Error: " + e.message);
      }
    });

    document.getElementById("btn-generate").addEventListener("click", async () => {
      hideError();
      const modal = document.getElementById("generate-modal");
      const select = document.getElementById("seed-select");

      const res = await fetch(`${API}/seeds?status=approved`);
      const seeds = await res.json();
      select.innerHTML = seeds.length
        ? seeds.map(s => `<option value="${s.id}">${esc(s.title)}</option>`).join("")
        : '<option value="">No approved seeds available</option>';

      modal.showModal();
    });

    document.getElementById("modal-cancel").addEventListener("click", () => {
      document.getElementById("generate-modal").close();
    });

    document.getElementById("modal-generate").addEventListener("click", async () => {
      const seedId = document.getElementById("seed-select").value;
      if (!seedId) { showError("Select a seed first."); return; }

      const btn = document.getElementById("modal-generate");
      btn.disabled = true;
      btn.textContent = "Generating...";
      hideError();

      try {
        const res = await fetch(`${API}/ideas/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ seed_id: seedId, interests: "" }),
        });
        if (!res.ok) throw new Error(await getErrorMsg(res));
        document.getElementById("generate-modal").close();
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generate";
      }
    });

    // ── Filters ──

    function escAttr(str) {
      return esc(str).replace(/"/g, "&quot;");
    }

    function renderFilters() {
      const container = document.getElementById("active-filters");
      container.innerHTML = "";

      if (activeTypes.has("status")) {
        const checked = new Set(filters.statuses);
        const checkboxes = ALL_STATUSES.map(st => `
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-xs" data-status="${st}" ${checked.has(st) ? "checked" : ""} />
            <span class="badge badge-sm badge-soft badge-${STATUS_LABELS[st]}">${st}</span>
          </label>`).join("");
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Status</span>
            <div class="flex items-center gap-1.5 flex-wrap">${checkboxes}</div>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="status" aria-label="Remove status filter">✕</button>
          </div>`;
      }

      if (activeTypes.has("keyword")) {
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Keyword</span>
            <input type="text" class="input input-xs w-40" id="filter-q" placeholder="search title, summary" value="${escAttr(filters.q)}" />
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="keyword" aria-label="Remove keyword filter">✕</button>
          </div>`;
      }

      updateAddFilterMenu();
      bindFilterEvents();
    }

    function updateAddFilterMenu() {
      document.querySelectorAll("[data-add-filter]").forEach(btn => {
        const type = btn.dataset.addFilter;
        const li = btn.closest("li");
        if (activeTypes.has(type)) {
          li.classList.add("hidden");
        } else {
          li.classList.remove("hidden");
        }
      });
    }

    function bindFilterEvents() {
      document.querySelectorAll("[data-remove-filter]").forEach(btn => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.removeFilter;
          activeTypes.delete(type);
          if (type === "status") filters.statuses = [];
          if (type === "keyword") filters.q = "";
          renderFilters();
          load();
        });
      });

      document.querySelectorAll("[data-status]").forEach(cb => {
        cb.addEventListener("change", () => {
          filters.statuses = Array.from(document.querySelectorAll("[data-status]:checked")).map(el => el.dataset.status);
          load();
        });
      });

      const qInput = document.getElementById("filter-q");
      if (qInput) {
        qInput.addEventListener("input", () => {
          filters.q = qInput.value;
          clearTimeout(qInput._t);
          qInput._t = setTimeout(load, 300);
        });
      }
    }

    document.querySelectorAll("[data-add-filter]").forEach(btn => {
      btn.addEventListener("click", () => {
        const type = btn.dataset.addFilter;
        if (activeTypes.has(type)) return;
        activeTypes.add(type);
        const dropdown = btn.closest("details");
        if (dropdown) dropdown.open = false;
        renderFilters();
        load();
      });
    });

    renderFilters();
    load();
  </script>
</Layout>
