---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Icon from "../components/Icon.astro";
---

<Layout title="Borradores">
  <Nav />
  <main id="main" class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 gap-2 flex-wrap">
      <h1 class="text-2xl font-bold">Borradores</h1>
      <div class="flex gap-2 flex-wrap">
        <button class="btn btn-sm btn-outline gap-1.5" id="btn-run-scheduler" title="Publica los borradores programados cuya fecha ya ha llegado">
          <Icon name="play" size={14} /> Ejecutar planificador
        </button>
        <button class="btn btn-primary gap-1.5" id="btn-generate">
          <Icon name="sparkles" size={16} /> Generar desde idea
        </button>
      </div>
    </div>

    <div id="error-msg" class="alert mb-4 hidden"></div>

    <div id="filters-bar" class="flex items-center gap-2 flex-wrap mb-4">
      <details class="dropdown">
        <summary class="btn btn-sm btn-outline gap-1.5">
          <Icon name="sliders" size={14} /> Añadir filtro
        </summary>
        <ul class="dropdown-content menu bg-base-100 border border-base-300 rounded-box z-10 w-48 p-2 shadow-sm">
          <li><button data-add-filter="status">Estado</button></li>
          <li><button data-add-filter="platform">Plataforma</button></li>
          <li><button data-add-filter="keyword">Palabra clave</button></li>
        </ul>
      </details>
      <div id="active-filters" class="flex items-center gap-2 flex-wrap"></div>
    </div>

    <div id="drafts-list">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando…</span>
    </div>
  </main>

  <dialog id="generate-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generar borradores</legend>
        <label class="label" for="idea-select">Idea</label>
        <select id="idea-select" class="select w-full">
          <option value="">Cargando ideas…</option>
        </select>
        <label class="label">Plataformas</label>
        <label class="label cursor-pointer justify-start gap-3">
          <input type="checkbox" value="twitter" checked class="checkbox checkbox-primary" />
          <span class="label-text">Twitter / X</span>
        </label>
        <label class="label cursor-pointer justify-start gap-3">
          <input type="checkbox" value="linkedin" checked class="checkbox checkbox-primary" />
          <span class="label-text">LinkedIn</span>
        </label>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="modal-cancel">Cancelar</button>
        <button class="btn btn-primary" id="modal-generate">Generar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="confirm-dialog" class="modal">
    <div class="modal-box">
      <p class="py-2" id="confirm-msg">¿Seguro?</p>
      <div class="modal-action">
        <button class="btn" id="confirm-no">Cancelar</button>
        <button class="btn btn-primary" id="confirm-yes">Confirmar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="prompt-dialog" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold" id="prompt-msg">Motivo:</legend>
        <input type="text" id="prompt-input" class="input w-full" />
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="prompt-cancel">Cancelar</button>
        <button class="btn btn-primary" id="prompt-ok">Aceptar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { icon } from "~/scripts/icons";
    import { byId, qAll, esc, escAttr, getErrorMessage } from "~/scripts/dom";
    import type { Draft, Idea, SchedulerResult } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const errorEl = byId("error-msg");

    const ALL_STATUSES = ["draft", "approved", "rejected", "published", "failed"];
    const STATUS_LABELS: Record<string, string> = {
      draft: "warning",
      approved: "info",
      rejected: "error",
      published: "success",
      failed: "error",
    };
    const STATUS_ES: Record<string, string> = {
      draft: "borrador",
      approved: "aprobado",
      rejected: "rechazado",
      published: "publicado",
      failed: "fallido",
    };
    const statusLabel = (s: string) => STATUS_ES[s] || s;
    const ALL_PLATFORMS = ["twitter", "linkedin"];

    const filters = { statuses: [] as string[], platforms: [] as string[], q: "" };
    const activeTypes = new Set<string>();

    const urlParams = new URLSearchParams(window.location.search);
    const seedStatus = urlParams.get("status");
    if (seedStatus && ALL_STATUSES.includes(seedStatus)) {
      filters.statuses = [seedStatus];
      activeTypes.add("status");
    }

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove("alert-info");
      errorEl.classList.add("alert-error");
      errorEl.classList.remove("hidden");
    }

    function showInfo(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove("alert-error");
      errorEl.classList.add("alert-info");
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    function askConfirm(msg: string) {
      return new Promise<boolean>((resolve) => {
        const dialog = byId<HTMLDialogElement>("confirm-dialog");
        byId("confirm-msg").textContent = msg;
        dialog.showModal();
        setTimeout(() => byId<HTMLButtonElement>("confirm-yes").focus(), 0);
        byId<HTMLButtonElement>("confirm-yes").onclick = () => {
          dialog.close();
          resolve(true);
        };
        byId<HTMLButtonElement>("confirm-no").onclick = () => {
          dialog.close();
          resolve(false);
        };
      });
    }

    function askPrompt(msg: string) {
      return new Promise<string | null>((resolve) => {
        const dialog = byId<HTMLDialogElement>("prompt-dialog");
        byId("prompt-msg").textContent = msg;
        const input = byId<HTMLInputElement>("prompt-input");
        input.value = "";
        dialog.showModal();
        setTimeout(() => input.focus(), 0);
        byId<HTMLButtonElement>("prompt-ok").onclick = () => {
          dialog.close();
          resolve(input.value);
        };
        byId<HTMLButtonElement>("prompt-cancel").onclick = () => {
          dialog.close();
          resolve(null);
        };
      });
    }

    function statusBadge(d: Draft) {
      const colors: Record<string, string> = {
        draft: "badge-warning",
        approved: "badge-info",
        rejected: "badge-error",
        published: "badge-success",
        failed: "badge-error",
      };
      return `<span class="badge badge-sm badge-soft ${colors[d.status] || "badge-ghost"}" title="Estado ${statusLabel(d.status)}">${statusLabel(d.status)}</span>`;
    }

    function mediaCell(d: Draft) {
      const urls = d.media_urls || [];
      const paths = d.media_paths || [];
      const all = [
        ...urls.map((u) => ({ src: u })),
        ...paths.map((p) => ({ src: `${API}/media/${p.split("/").pop()}` })),
      ];
      if (!all.length) return '<span class="text-base-content/30">—</span>';
      return `<div class="flex gap-1">${all
        .slice(0, 3)
        .map(
          (m) =>
            `<img src="${esc(m.src)}" class="w-8 h-8 object-cover rounded" alt="Vista previa del medio" loading="lazy" />`
        )
        .join("")}${all.length > 3 ? `<span class="text-xs text-base-content/60 self-center">+${all.length - 3}</span>` : ""}</div>`;
    }

    function scheduledCell(d: Draft) {
      return d.scheduled_at
        ? `<span class="badge badge-sm badge-soft badge-secondary whitespace-nowrap" title="${esc(d.scheduled_at)}">${icon("calendar", 12, "inline-block")} ${new Date(d.scheduled_at).toLocaleString()}</span>`
        : '<span class="text-base-content/30">—</span>';
    }

    function draftActions(d: Draft) {
      const parts: string[] = [
        `<a href="/drafts/edit?id=${d.id}" class="btn btn-square btn-ghost btn-sm" aria-label="Editar borrador" title="Editar borrador">${icon("edit", 16)}</a>`,
      ];
      if (d.status === "draft") {
        parts.push(
          `<button class="btn btn-square btn-ghost btn-sm text-success" data-action="approve" data-id="${d.id}" aria-label="Aprobar borrador" title="Aprobar borrador">${icon("check", 16)}</button>`
        );
        parts.push(
          `<button class="btn btn-square btn-ghost btn-sm text-error" data-action="reject" data-id="${d.id}" aria-label="Rechazar borrador" title="Rechazar (pedir motivo)">${icon("circle-x", 16)}</button>`
        );
      }
      if (d.status === "approved") {
        parts.push(
          `<button class="btn btn-square btn-ghost btn-sm text-primary" data-action="publish" data-id="${d.id}" aria-label="Publicar borrador" title="Publicar borrador">${icon("send", 16)}</button>`
        );
      }
      if (d.scheduled_at) {
        parts.push(
          `<button class="btn btn-square btn-ghost btn-sm" data-action="unschedule" data-id="${d.id}" aria-label="Cancelar programación" title="Cancelar programación">${icon("calendar-x", 16)}</button>`
        );
      }
      return parts.join("");
    }

    async function load() {
      hideError();
      const params = new URLSearchParams();
      filters.statuses.forEach((s) => params.append("statuses", s));
      filters.platforms.forEach((p) => params.append("platforms", p));
      if (filters.q) params.set("q", filters.q);
      const qs = params.toString();
      const res = await fetch(`${API}/drafts${qs ? "?" + qs : ""}`);
      const drafts = (await res.json()) as Draft[];
      const container = byId("drafts-list");

      if (!drafts.length) {
        container.innerHTML =
          '<div class="alert bg-base-200 text-sm">Aún no hay borradores. Pulsa "Generar desde idea" para crear algunos.</div>';
        return;
      }

      const rows = drafts
        .map(
          (d) => `
          <tr>
            <td><span class="badge badge-sm badge-ghost capitalize">${esc(d.platform)}</span></td>
            <td><div class="text-sm text-base-content/70 max-w-xs truncate" title="${esc(d.content || "")}">${d.content ? esc(d.content.substring(0, 100)) + (d.content.length > 100 ? "…" : "") : "—"}</div></td>
            <td>${mediaCell(d)}</td>
            <td>${statusBadge(d)}</td>
            <td>${scheduledCell(d)}</td>
            <td class="text-sm text-base-content/60">${d.created_at ? new Date(d.created_at).toLocaleDateString() : "—"}</td>
            <td><div class="flex gap-1">${draftActions(d)}</div></td>
          </tr>`
        )
        .join("");

      const cards = drafts
        .map(
          (d) => `
          <div class="card bg-base-100 border border-base-300 shadow-sm">
            <div class="card-body p-4 gap-2">
              <div class="flex items-center justify-between gap-2">
                <span class="badge badge-sm badge-ghost capitalize">${esc(d.platform)}</span>
                ${statusBadge(d)}
              </div>
              <p class="text-sm text-base-content/80 line-clamp-3">${d.content ? esc(d.content.substring(0, 200)) + (d.content.length > 200 ? "…" : "") : "—"}</p>
              ${mediaCell(d)}
              <div class="flex items-center justify-between gap-2 text-xs text-base-content/60 flex-wrap">
                <span>${scheduledCell(d)}</span>
                <span>${d.created_at ? new Date(d.created_at).toLocaleDateString() : "—"}</span>
              </div>
              <div class="flex gap-1 pt-1 border-t border-base-200">${draftActions(d)}</div>
            </div>
          </div>`
        )
        .join("");

      container.innerHTML = `
        <div class="hidden md:block overflow-x-auto">
          <table class="table table-zinc">
            <thead>
              <tr>
                <th>Plataforma</th>
                <th>Contenido</th>
                <th>Multimedia</th>
                <th>Estado</th>
                <th>Programado</th>
                <th>Creado</th>
                <th><span class="sr-only">Acciones</span></th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
        <div class="md:hidden flex flex-col gap-3">${cards}</div>`;
    }

    byId("drafts-list").addEventListener("click", async (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-action]");
      if (!btn) return;
      hideError();
      const id = btn.dataset.id ?? "";

      try {
        switch (btn.dataset.action) {
          case "approve": {
            const res = await fetch(`${API}/drafts/${id}`, {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ status: "approved" }),
            });
            if (!res.ok) throw new Error(await getErrorMessage(res));
            break;
          }
          case "reject": {
            const notes = await askPrompt("Motivo del rechazo (opcional):");
            if (notes === null) return;
            const res = await fetch(`${API}/drafts/${id}`, {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ status: "rejected", notes }),
            });
            if (!res.ok) throw new Error(await getErrorMessage(res));
            break;
          }
          case "publish": {
            const ok = await askConfirm("¿Publicar este borrador?");
            if (!ok) return;
            const res = await fetch(`${API}/publish/${id}`, { method: "POST" });
            if (!res.ok) throw new Error(await getErrorMessage(res));
            break;
          }
          case "unschedule": {
            const ok = await askConfirm("¿Cancelar la programación de este borrador?");
            if (!ok) return;
            const res = await fetch(`${API}/drafts/${id}/unschedule`, { method: "POST" });
            if (!res.ok) throw new Error(await getErrorMessage(res));
            break;
          }
        }
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      }
    });

    byId("btn-run-scheduler").addEventListener("click", async () => {
      hideError();
      const btn = byId<HTMLButtonElement>("btn-run-scheduler");
      btn.disabled = true;
      btn.textContent = "Ejecutando…";
      try {
        const res = await fetch(`${API}/scheduler/run`, { method: "POST" });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        const data = (await res.json()) as SchedulerResult;
        if (data.published === 0 && data.failed === 0) {
          showInfo("No hay borradores listos para publicar.");
        } else {
          showInfo(`Planificador: ${data.published} publicados, ${data.failed} fallidos.`);
        }
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = `${icon("play", 14)} Ejecutar planificador`;
      }
    });

    byId("btn-generate").addEventListener("click", async () => {
      hideError();
      const modal = byId<HTMLDialogElement>("generate-modal");
      const select = byId<HTMLSelectElement>("idea-select");

      const res = await fetch(`${API}/ideas?status=pending`);
      const ideas = (await res.json()) as Idea[];
      select.innerHTML = ideas.length
        ? ideas.map((i) => `<option value="${i.id}">${esc(i.title)}</option>`).join("")
        : '<option value="">No hay ideas pendientes</option>';

      modal.showModal();
      setTimeout(() => select.focus(), 0);
    });

    byId("modal-cancel").addEventListener("click", () => {
      byId<HTMLDialogElement>("generate-modal").close();
    });

    byId("modal-generate").addEventListener("click", async () => {
      const ideaId = byId<HTMLSelectElement>("idea-select").value;
      if (!ideaId) {
        showError("Selecciona una idea.");
        return;
      }

      const platforms = qAll<HTMLInputElement>("#generate-modal input[type=checkbox]:checked").map(
        (cb) => cb.value
      );
      if (!platforms.length) {
        showError("Selecciona al menos una plataforma.");
        return;
      }

      const btn = byId<HTMLButtonElement>("modal-generate");
      btn.disabled = true;
      btn.textContent = "Generando…";
      hideError();

      try {
        const res = await fetch(`${API}/drafts/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ idea_id: ideaId, platforms }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        byId<HTMLDialogElement>("generate-modal").close();
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generar";
      }
    });

    // ── Filtros ──

    function renderFilters() {
      const container = byId("active-filters");
      container.innerHTML = "";

      if (activeTypes.has("status")) {
        const checked = new Set(filters.statuses);
        const checkboxes = ALL_STATUSES.map(
          (st) => `
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-xs" data-status="${st}" ${checked.has(st) ? "checked" : ""} />
            <span class="badge badge-sm badge-soft badge-${STATUS_LABELS[st]}">${statusLabel(st)}</span>
          </label>`
        ).join("");
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Estado</span>
            <div class="flex items-center gap-1.5 flex-wrap">${checkboxes}</div>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="status" aria-label="Quitar filtro de estado" title="Quitar filtro de estado">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("platform")) {
        const checked = new Set(filters.platforms);
        const checkboxes = ALL_PLATFORMS.map(
          (p) => `
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-xs" data-platform="${p}" ${checked.has(p) ? "checked" : ""} />
            <span class="badge badge-sm badge-soft capitalize">${p}</span>
          </label>`
        ).join("");
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Plataforma</span>
            <div class="flex items-center gap-1.5 flex-wrap">${checkboxes}</div>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="platform" aria-label="Quitar filtro de plataforma" title="Quitar filtro de plataforma">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("keyword")) {
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Palabra clave</span>
            <input type="text" class="input input-xs w-40" id="filter-q" placeholder="buscar contenido" value="${escAttr(filters.q)}" />
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="keyword" aria-label="Quitar filtro de palabra clave" title="Quitar filtro de palabra clave">${icon("close", 14)}</button>
          </div>`;
      }

      updateAddFilterMenu();
      bindFilterEvents();
    }

    function updateAddFilterMenu() {
      qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
        const type = btn.dataset.addFilter ?? "";
        const li = btn.closest("li");
        if (!li) return;
        if (activeTypes.has(type)) {
          li.classList.add("hidden");
        } else {
          li.classList.remove("hidden");
        }
      });
    }

    function bindFilterEvents() {
      qAll<HTMLButtonElement>("[data-remove-filter]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.removeFilter ?? "";
          activeTypes.delete(type);
          if (type === "status") filters.statuses = [];
          if (type === "platform") filters.platforms = [];
          if (type === "keyword") filters.q = "";
          renderFilters();
          load();
        });
      });

      qAll<HTMLInputElement>("[data-status]").forEach((cb) => {
        cb.addEventListener("change", () => {
          filters.statuses = qAll<HTMLInputElement>("[data-status]:checked")
            .map((el) => el.dataset.status ?? "")
            .filter(Boolean);
          load();
        });
      });

      qAll<HTMLInputElement>("[data-platform]").forEach((cb) => {
        cb.addEventListener("change", () => {
          filters.platforms = qAll<HTMLInputElement>("[data-platform]:checked")
            .map((el) => el.dataset.platform ?? "")
            .filter(Boolean);
          load();
        });
      });

      const qInput = byId<HTMLInputElement>("filter-q");
      if (qInput) {
        qInput.addEventListener("input", () => {
          filters.q = qInput.value;
          clearTimeout(qInput._t);
          qInput._t = setTimeout(load, 300);
        });
      }
    }

    qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.dataset.addFilter ?? "";
        if (activeTypes.has(type)) return;
        activeTypes.add(type);
        const dropdown = btn.closest("details");
        if (dropdown) dropdown.open = false;
        renderFilters();
        load();
      });
    });

    renderFilters();
    load();
  </script>
</Layout>
