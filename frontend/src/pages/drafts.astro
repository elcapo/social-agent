---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Drafts">
  <Nav />
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">Drafts</h1>
      <button class="btn btn-primary" id="btn-generate">Generate from idea</button>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="drafts-list"><span class="loading loading-spinner loading-sm"></span> <span class="text-sm text-base-content/40">Loading...</span></div>
  </main>

  <dialog id="generate-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generate Drafts</legend>
        <label class="label">Idea</label>
        <select id="idea-select" class="select w-full">
          <option value="">Loading ideas...</option>
        </select>
        <label class="label">Platforms</label>
        <label class="label cursor-pointer justify-start gap-3">
          <input type="checkbox" value="twitter" checked class="checkbox checkbox-primary" />
          <span class="label-text">Twitter / X</span>
        </label>
        <label class="label cursor-pointer justify-start gap-3">
          <input type="checkbox" value="linkedin" checked class="checkbox checkbox-primary" />
          <span class="label-text">LinkedIn</span>
        </label>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="modal-cancel">Cancel</button>
        <button class="btn btn-primary" id="modal-generate">Generate</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="confirm-dialog" class="modal">
    <div class="modal-box">
      <p class="py-2" id="confirm-msg">Are you sure?</p>
      <div class="modal-action">
        <button class="btn" id="confirm-no">Cancel</button>
        <button class="btn btn-primary" id="confirm-yes">Confirm</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="prompt-dialog" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold" id="prompt-msg">Reason:</legend>
        <input type="text" id="prompt-input" class="input w-full" />
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="prompt-cancel">Cancel</button>
        <button class="btn btn-primary" id="prompt-ok">OK</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const filterStatus = params.get("status");

    const errorEl = document.getElementById("error-msg");

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    async function getErrorMsg(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    function esc(str) {
      if (!str) return "";
      const d = document.createElement("div");
      d.appendChild(document.createTextNode(str));
      return d.innerHTML;
    }

    function askConfirm(msg) {
      return new Promise(resolve => {
        const dialog = document.getElementById("confirm-dialog");
        document.getElementById("confirm-msg").textContent = msg;
        dialog.showModal();
        document.getElementById("confirm-yes").onclick = () => { dialog.close(); resolve(true); };
        document.getElementById("confirm-no").onclick = () => { dialog.close(); resolve(false); };
      });
    }

    function askPrompt(msg) {
      return new Promise(resolve => {
        const dialog = document.getElementById("prompt-dialog");
        document.getElementById("prompt-msg").textContent = msg;
        const input = document.getElementById("prompt-input");
        input.value = "";
        dialog.showModal();
        input.focus();
        document.getElementById("prompt-ok").onclick = () => { dialog.close(); resolve(input.value); };
        document.getElementById("prompt-cancel").onclick = () => { dialog.close(); resolve(null); };
      });
    }

    async function load() {
      hideError();
      let url = `${API}/drafts`;
      if (filterStatus) url += `?status=${filterStatus}`;
      const res = await fetch(url);
      const drafts = await res.json();
      const container = document.getElementById("drafts-list");

      if (!drafts.length) {
        container.innerHTML = '<div class="alert bg-base-200 text-sm">No drafts yet. Click "Generate from seed" to create some.</div>';
        return;
      }

      container.innerHTML = `<div class="overflow-x-auto"><table class="table table-zinc">
        <thead>
          <tr>
            <th>Platform</th>
            <th>Content</th>
            <th>Media</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>${drafts.map(d => `
          <tr>
            <td><span class="font-semibold text-xs uppercase tracking-wider">${esc(d.platform)}</span></td>
            <td><div class="text-sm text-base-content/60 max-w-xs truncate">${d.content ? esc(d.content.substring(0, 100)) + (d.content.length > 100 ? "…" : "") : "—"}</div></td>
            <td>${(() => {
              const urls = d.media_urls || [];
              const paths = d.media_paths || [];
              const allMedia = [...urls.map(u => ({ type: "url", src: u })), ...paths.map(p => ({ type: "path", src: `${API}/media/${p.split("/").pop()}` }))];
              if (!allMedia.length) return '<span class="text-base-content/20">—</span>';
              return `<div class="flex gap-1">${allMedia.slice(0, 3).map(m => `<img src="${esc(m.src)}" class="w-8 h-8 object-cover rounded" alt="" />`).join("")}${allMedia.length > 3 ? `<span class="text-xs text-base-content/40">+${allMedia.length - 3}</span>` : ""}</div>`;
            })()}</td>
            <td><span class="badge badge-sm badge-soft ${d.status === "draft" ? "badge-warning" : d.status === "approved" ? "badge-info" : d.status === "published" ? "badge-success" : "badge-error"}">${d.status}</span></td>
            <td class="text-sm text-base-content/40">${d.created_at ? new Date(d.created_at).toLocaleDateString() : "—"}</td>
            <td><div class="flex gap-1"><a href="/drafts/edit?id=${d.id}" class="btn btn-square btn-ghost btn-sm" aria-label="Edit draft"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></a>${d.status === "draft"
              ? `<button class="btn btn-ghost btn-xs text-success" data-action="approve" data-id="${d.id}" aria-label="Approve draft">Approve</button><button class="btn btn-ghost btn-xs text-error" data-action="reject" data-id="${d.id}" aria-label="Reject draft">Reject</button>`
              : d.status === "approved"
              ? `<button class="btn btn-ghost btn-xs text-primary" data-action="publish" data-id="${d.id}" aria-label="Publish draft">Publish</button>`
              : ""}</div></td>
          </tr>`).join("")}</tbody>
      </table></div>`;
    }

    document.getElementById("drafts-list").addEventListener("click", async (e) => {
      const btn = e.target.closest("[data-action]");
      if (!btn) return;
      hideError();

      try {
        switch (btn.dataset.action) {
          case "approve": {
            const res = await fetch(`${API}/drafts/${btn.dataset.id}`, {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ status: "approved" }),
            });
            if (!res.ok) throw new Error(await getErrorMsg(res));
            break;
          }
          case "reject": {
            const notes = await askPrompt("Reason for rejection (optional):");
            if (notes === null) return;
            const res = await fetch(`${API}/drafts/${btn.dataset.id}`, {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ status: "rejected", notes }),
            });
            if (!res.ok) throw new Error(await getErrorMsg(res));
            break;
          }
          case "publish": {
            const ok = await askConfirm("Publish this draft?");
            if (!ok) return;
            const res = await fetch(`${API}/publish/${btn.dataset.id}`, { method: "POST" });
            if (!res.ok) throw new Error(await getErrorMsg(res));
            break;
          }
        }
        load();
      } catch (e) {
        showError("Error: " + e.message);
      }
    });

    document.getElementById("btn-generate").addEventListener("click", async () => {
      hideError();
      const modal = document.getElementById("generate-modal");
      const select = document.getElementById("idea-select");

      const res = await fetch(`${API}/ideas?status=pending`);
      const ideas = await res.json();
      select.innerHTML = ideas.length
        ? ideas.map(i => `<option value="${i.id}">${esc(i.title)}</option>`).join("")
        : '<option value="">No pending ideas available</option>';

      modal.showModal();
    });

    document.getElementById("modal-cancel").addEventListener("click", () => {
      document.getElementById("generate-modal").close();
    });

    document.getElementById("modal-generate").addEventListener("click", async () => {
      const ideaId = document.getElementById("idea-select").value;
      if (!ideaId) { showError("Select an idea first."); return; }

      const checkboxes = document.querySelectorAll("#generate-modal input[type=checkbox]:checked");
      const platforms = Array.from(checkboxes).map(cb => cb.value);
      if (!platforms.length) { showError("Select at least one platform."); return; }

      const btn = document.getElementById("modal-generate");
      btn.disabled = true;
      btn.textContent = "Generating...";
      hideError();

      try {
        const res = await fetch(`${API}/drafts/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ idea_id: ideaId, platforms }),
        });
        if (!res.ok) throw new Error(await getErrorMsg(res));
        document.getElementById("generate-modal").close();
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generate";
      }
    });

    load();
  </script>
</Layout>
