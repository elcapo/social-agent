---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
---

<Layout title="Edit Idea">
  <Nav />
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/ideas" class="link link-hover text-sm text-base-content/50">&larr; Back to ideas</a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Edit Idea</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/40">Loading idea...</span>
    </div>

    <div id="form-container" class="hidden">
      <div id="readonly-notice" class="alert alert-info mb-4 hidden">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        <span id="readonly-msg"></span>
      </div>

      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Idea details</legend>

        <label class="label">Status</label>
        <div id="idea-status-display"></div>

        <label class="label">Title</label>
        <input type="text" id="idea-title" class="input w-full" placeholder="Idea title" />

        <label class="label">Summary</label>
        <textarea id="idea-summary" class="textarea w-full" rows="8" placeholder="Idea summary..."></textarea>

        <label class="label">Seed ID</label>
        <input type="text" id="idea-seed-id" class="input w-full" disabled />

        <label class="label">Source URL</label>
        <input type="url" id="idea-source-url" class="input w-full" placeholder="https://..." disabled />

        <label class="label">Created</label>
        <div id="idea-created" class="text-sm text-base-content/60"></div>
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/ideas" class="btn">Cancel</a>
        <button class="btn btn-primary" id="btn-save">Save changes</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Idea not found.</div>
      <a href="/ideas" class="btn btn-ghost mt-4">&larr; Back to ideas</a>
    </div>
  </main>

  <script>
    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const ideaId = params.get("id");

    const errorEl = document.getElementById("error-msg");
    const successEl = document.getElementById("success-msg");
    const loadingEl = document.getElementById("loading");
    const formContainer = document.getElementById("form-container");
    const notFoundEl = document.getElementById("not-found");
    const readonlyNotice = document.getElementById("readonly-notice");
    const readonlyMsg = document.getElementById("readonly-msg");
    const btnSave = document.getElementById("btn-save");
    const editableInputs = ["idea-title", "idea-summary"].map(id => document.getElementById(id));

    const READONLY_STATUSES = ["used", "discarded"];

    function setFormEditable(editable) {
      editableInputs.forEach(el => { el.disabled = !editable; el.readOnly = !editable; });
      if (editable) {
        readonlyNotice.classList.add("hidden");
        btnSave.classList.remove("hidden");
      } else {
        btnSave.classList.add("hidden");
      }
    }

    function setStatusBadge(status) {
      const colors = { pending: "badge-warning", used: "badge-success", discarded: "badge-error" };
      return `<span class="badge badge-md badge-soft ${colors[status] || "badge-ghost"}">${status}</span>`;
    }

    function showError(msg) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    async function getErrorMessage(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    async function load() {
      if (!ideaId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/ideas/${ideaId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const idea = await res.json();
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      document.getElementById("page-title").textContent = `Edit: ${idea.title}`;
      document.getElementById("idea-status-display").innerHTML = setStatusBadge(idea.status);
      document.getElementById("idea-title").value = idea.title;
      document.getElementById("idea-summary").value = idea.summary || "";
      document.getElementById("idea-seed-id").value = idea.seed_id || "";
      document.getElementById("idea-source-url").value = idea.source_url || "";
      document.getElementById("idea-created").textContent = idea.created_at ? new Date(idea.created_at).toLocaleString() : "—";

      const readOnly = READONLY_STATUSES.includes(idea.status);
      setFormEditable(!readOnly);
      if (readOnly) {
        readonlyMsg.textContent = `This idea is in "${idea.status}" state and cannot be modified.`;
        readonlyNotice.classList.remove("hidden");
      }
    }

    btnSave.addEventListener("click", async () => {
      const title = document.getElementById("idea-title").value.trim();
      const summary = document.getElementById("idea-summary").value.trim();

      if (!title) { showError("Title is required."); return; }

      btnSave.disabled = true;
      btnSave.textContent = "Saving...";
      hideAll();

      try {
        const body = { title, summary };
        const res = await fetch(`${API}/ideas/${ideaId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Idea updated successfully.");
        btnSave.textContent = "Saved!";
        setTimeout(() => { window.location.href = "/ideas"; }, 1000);
      } catch (e) {
        showError("Error: " + e.message);
        btnSave.disabled = false;
        btnSave.textContent = "Save changes";
      }
    });

    load();
  </script>
</Layout>
