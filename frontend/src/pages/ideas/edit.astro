---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Icon from "../../components/Icon.astro";
---

<Layout title="Editar idea">
  <Nav />
  <main id="main" class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/ideas" class="link link-hover text-sm text-base-content/60 inline-flex items-center gap-1 no-underline">
          <Icon name="arrow-left" size={14} /> Volver a ideas
        </a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Editar idea</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando idea…</span>
    </div>

    <div id="form-container" class="hidden">
      <div id="readonly-notice" class="alert alert-info mb-4 hidden gap-2">
        <Icon name="info" size={20} />
        <span id="readonly-msg"></span>
      </div>

      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Detalles de la idea</legend>

        <label class="label">Estado</label>
        <div id="idea-status-display"></div>

        <label class="label" for="idea-title">Título</label>
        <input type="text" id="idea-title" class="input w-full" placeholder="Título de la idea" />

        <label class="label" for="idea-summary">Resumen</label>
        <textarea id="idea-summary" class="textarea w-full" rows="8" placeholder="Resumen de la idea…"></textarea>

        <label class="label" for="idea-comment">Comentario (para el escritor)</label>
        <textarea id="idea-comment" class="textarea w-full" rows="4" placeholder="Contexto o instrucciones para el agente escritor, separadas del resumen de la noticia. Ej: &quot;empieza narrando la publicación del modelo e indicando que es de pesos abiertos&quot;"></textarea>
        <div class="text-xs text-base-content/60 mt-1">Se incluirá en el prompt del escritor como "Comentario del autor", distinguido del resumen de la noticia.</div>

        <label class="label" for="idea-seed-id">ID de semilla</label>
        <input type="text" id="idea-seed-id" class="input w-full" disabled />

        <label class="label" for="idea-source-url">URL de origen</label>
        <input type="url" id="idea-source-url" class="input w-full" placeholder="https://…" disabled />

        <label class="label">Creado</label>
        <div id="idea-created" class="text-sm text-base-content/60"></div>
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/ideas" class="btn">Cancelar</a>
        <button class="btn btn-primary" id="btn-save">Guardar cambios</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Idea no encontrada.</div>
      <a href="/ideas" class="btn btn-ghost mt-4 gap-1.5">
        <Icon name="arrow-left" size={16} /> Volver a ideas
      </a>
    </div>
  </main>

  <script>
    import { byId, getErrorMessage } from "~/scripts/dom";
    import type { Idea } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const ideaId = params.get("id");

    const errorEl = byId("error-msg");
    const successEl = byId("success-msg");
    const loadingEl = byId("loading");
    const formContainer = byId("form-container");
    const notFoundEl = byId("not-found");
    const readonlyNotice = byId("readonly-notice");
    const readonlyMsg = byId("readonly-msg");
    const btnSave = byId<HTMLButtonElement>("btn-save");
    const editableInputs: (HTMLInputElement | HTMLTextAreaElement)[] = [
      byId<HTMLInputElement>("idea-title"),
      byId<HTMLTextAreaElement>("idea-summary"),
      byId<HTMLTextAreaElement>("idea-comment"),
    ];

    const READONLY_STATUSES = ["used", "discarded"];
    const STATUS_ES: Record<string, string> = {
      pending: "pendiente",
      used: "usado",
      discarded: "descartado",
    };
    const statusLabel = (s: string) => STATUS_ES[s] || s;

    function setFormEditable(editable: boolean) {
      editableInputs.forEach((el) => {
        el.disabled = !editable;
        el.readOnly = !editable;
      });
      if (editable) {
        readonlyNotice.classList.add("hidden");
        btnSave.classList.remove("hidden");
      } else {
        btnSave.classList.add("hidden");
      }
    }

    function setStatusBadge(status: string) {
      const colors: Record<string, string> = {
        pending: "badge-warning",
        used: "badge-success",
        discarded: "badge-error",
      };
      return `<span class="badge badge-md badge-soft ${colors[status] || "badge-ghost"}" title="Estado ${statusLabel(status)}">${statusLabel(status)}</span>`;
    }

    function showError(msg: string) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg: string) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    async function load() {
      if (!ideaId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/ideas/${ideaId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const idea = (await res.json()) as Idea;
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      byId("page-title").textContent = `Editar: ${idea.title}`;
      byId("idea-status-display").innerHTML = setStatusBadge(idea.status);
      byId<HTMLInputElement>("idea-title").value = idea.title;
      byId<HTMLTextAreaElement>("idea-summary").value = idea.summary || "";
      byId<HTMLTextAreaElement>("idea-comment").value = idea.comment || "";
      byId<HTMLInputElement>("idea-seed-id").value = idea.seed_id || "";
      byId<HTMLInputElement>("idea-source-url").value = idea.source_url || "";
      byId("idea-created").textContent = idea.created_at
        ? new Date(idea.created_at).toLocaleString()
        : "—";

      const readOnly = READONLY_STATUSES.includes(idea.status);
      setFormEditable(!readOnly);
      if (readOnly) {
        readonlyMsg.textContent = `Esta idea está en estado "${statusLabel(idea.status)}" y no se puede modificar.`;
        readonlyNotice.classList.remove("hidden");
      } else {
        setTimeout(() => byId<HTMLInputElement>("idea-title").focus(), 0);
      }
    }

    btnSave.addEventListener("click", async () => {
      const title = byId<HTMLInputElement>("idea-title").value.trim();
      const summary = byId<HTMLTextAreaElement>("idea-summary").value.trim();
      const comment = byId<HTMLTextAreaElement>("idea-comment").value;

      if (!title) {
        showError("El título es obligatorio.");
        return;
      }

      btnSave.disabled = true;
      btnSave.textContent = "Guardando…";
      hideAll();

      try {
        const body = { title, summary, comment };
        const res = await fetch(`${API}/ideas/${ideaId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Idea actualizada correctamente.");
        btnSave.textContent = "¡Guardado!";
        setTimeout(() => {
          window.location.href = "/ideas";
        }, 1000);
      } catch (e) {
        showError("Error: " + (e as Error).message);
        btnSave.disabled = false;
        btnSave.textContent = "Guardar cambios";
      }
    });

    load();
  </script>
</Layout>
