---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Icon from "../../components/Icon.astro";
---

<Layout title="Editar borrador">
  <Nav />
  <main id="main" class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/drafts" class="link link-hover text-sm text-base-content/60 inline-flex items-center gap-1 no-underline">
          <Icon name="arrow-left" size={14} /> Volver a borradores
        </a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Editar borrador</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando borrador…</span>
    </div>

    <div id="form-container" class="hidden">
      <div id="readonly-notice" class="alert alert-info mb-4 hidden gap-2">
        <Icon name="info" size={20} />
        <span id="readonly-msg"></span>
      </div>

      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Detalles del borrador</legend>

        <label class="label">Estado</label>
        <div id="draft-status-display"></div>

        <label class="label" for="draft-platform">Plataforma</label>
        <input type="text" id="draft-platform" class="input w-full capitalize" disabled />

        <label class="label" for="draft-idea-id">ID de idea</label>
        <input type="text" id="draft-idea-id" class="input w-full" disabled />

        <label class="label" for="draft-content">Contenido</label>
        <textarea id="draft-content" class="textarea w-full h-48" placeholder="Contenido del borrador…"></textarea>

        <label class="label" for="draft-media-urls">URLs de medios (una por línea)</label>
        <textarea id="draft-media-urls" class="textarea w-full h-20" placeholder="https://ejemplo.com/imagen1.jpg"></textarea>

        <label class="label">Archivos locales</label>
        <div id="draft-media-paths" class="text-sm text-base-content/60"></div>

        <div id="draft-upload-section">
          <label class="label" for="draft-media-file">Subir nuevo archivo</label>
          <input type="file" id="draft-media-file" accept="image/*" class="file-input file-input-bordered w-full" />
        </div>

        <label class="label">Programación</label>
        <div id="draft-schedule-display" class="text-sm text-base-content/60 mb-2"></div>
        <div class="flex items-center gap-2 flex-wrap">
          <input type="datetime-local" id="draft-scheduled-at" class="input input-sm w-auto" />
          <button class="btn btn-sm btn-primary" id="btn-schedule">Programar</button>
          <button class="btn btn-sm btn-ghost" id="btn-unschedule">Quitar programación</button>
        </div>

        <label class="label">Notas</label>
        <div id="draft-notes" class="text-sm text-base-content/60"></div>

        <label class="label">Creado</label>
        <div id="draft-created" class="text-sm text-base-content/60"></div>
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/drafts" class="btn">Cancelar</a>
        <button class="btn" id="btn-upload-file">Subir archivo</button>
        <button class="btn btn-primary" id="btn-save">Guardar cambios</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Borrador no encontrado.</div>
      <a href="/drafts" class="btn btn-ghost mt-4 gap-1.5">
        <Icon name="arrow-left" size={16} /> Volver a borradores
      </a>
    </div>
  </main>

  <script>
    import { icon } from "~/scripts/icons";
    import { byId, esc, getErrorMessage } from "~/scripts/dom";
    import type { Draft } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const draftId = params.get("id");

    const errorEl = byId("error-msg");
    const successEl = byId("success-msg");
    const loadingEl = byId("loading");
    const formContainer = byId("form-container");
    const notFoundEl = byId("not-found");
    const readonlyNotice = byId("readonly-notice");
    const readonlyMsg = byId("readonly-msg");
    const btnSave = byId<HTMLButtonElement>("btn-save");
    const btnUpload = byId<HTMLButtonElement>("btn-upload-file");
    const btnSchedule = byId<HTMLButtonElement>("btn-schedule");
    const btnUnschedule = byId<HTMLButtonElement>("btn-unschedule");
    const scheduleInput = byId<HTMLInputElement>("draft-scheduled-at");
    const uploadSection = byId("draft-upload-section");
    const editableInputs: HTMLTextAreaElement[] = [
      byId<HTMLTextAreaElement>("draft-content"),
      byId<HTMLTextAreaElement>("draft-media-urls"),
    ];

    const READONLY_STATUSES = ["approved", "rejected", "published", "failed"];
    const STATUS_ES: Record<string, string> = {
      draft: "borrador",
      approved: "aprobado",
      rejected: "rechazado",
      published: "publicado",
      failed: "fallido",
    };
    const statusLabel = (s: string) => STATUS_ES[s] || s;

    function setFormEditable(editable: boolean) {
      editableInputs.forEach((el) => {
        el.disabled = !editable;
        el.readOnly = !editable;
      });
      if (editable) {
        readonlyNotice.classList.add("hidden");
        btnSave.classList.remove("hidden");
        btnUpload.classList.remove("hidden");
        uploadSection.classList.remove("hidden");
      } else {
        btnSave.classList.add("hidden");
        btnUpload.classList.add("hidden");
        uploadSection.classList.add("hidden");
      }
    }

    function setStatusBadge(status: string) {
      const colors: Record<string, string> = {
        draft: "badge-warning",
        approved: "badge-info",
        rejected: "badge-error",
        published: "badge-success",
        failed: "badge-error",
      };
      return `<span class="badge badge-md badge-soft ${colors[status] || "badge-ghost"}" title="Estado ${statusLabel(status)}">${statusLabel(status)}</span>`;
    }

    function showError(msg: string) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg: string) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    function updateMediaPathsDisplay(paths: string[] | undefined) {
      const container = byId("draft-media-paths");
      if (!paths || !paths.length) {
        container.innerHTML = '<span class="text-base-content/60">Sin archivos locales</span>';
        return;
      }
      container.innerHTML = paths
        .map(
          (p) =>
            `<div class="flex items-center gap-2">${icon("file", 14)} ${esc(p.split("/").pop())}</div>`
        )
        .join("");
    }

    function toLocalInputValue(iso: string | null | undefined) {
      if (!iso) return "";
      const d = new Date(iso);
      if (isNaN(d.getTime())) return "";
      const pad = (n: number) => String(n).padStart(2, "0");
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function updateScheduleDisplay(scheduledAt: string | null | undefined, status: string) {
      const display = byId("draft-schedule-display");
      const published = status === "published";
      if (scheduledAt) {
        display.innerHTML = `<span class="badge badge-sm badge-soft badge-secondary" title="${esc(scheduledAt)}">${icon("calendar", 12, "inline-block")} ${new Date(scheduledAt).toLocaleString()}</span>`;
      } else {
        display.innerHTML = '<span class="text-base-content/60">Sin programar</span>';
      }
      scheduleInput.value = toLocalInputValue(scheduledAt);
      scheduleInput.disabled = published;
      btnSchedule.disabled = published;
      btnUnschedule.disabled = published || !scheduledAt;
    }

    async function load() {
      if (!draftId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/drafts/${draftId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const draft = (await res.json()) as Draft;
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      byId("page-title").textContent = `Editar: borrador de ${draft.platform}`;
      byId("draft-status-display").innerHTML = setStatusBadge(draft.status);
      byId<HTMLInputElement>("draft-platform").value = draft.platform;
      byId<HTMLInputElement>("draft-idea-id").value = draft.idea_id || "";
      byId<HTMLTextAreaElement>("draft-content").value = draft.content;
      byId<HTMLTextAreaElement>("draft-media-urls").value = (draft.media_urls || []).join("\n");
      updateMediaPathsDisplay(draft.media_paths);
      updateScheduleDisplay(draft.scheduled_at, draft.status);
      byId("draft-notes").textContent = draft.notes || "—";
      byId("draft-created").textContent = draft.created_at
        ? new Date(draft.created_at).toLocaleString()
        : "—";

      const readOnly = READONLY_STATUSES.includes(draft.status);
      setFormEditable(!readOnly);
      if (readOnly) {
        readonlyMsg.textContent = `Este borrador está en estado "${statusLabel(draft.status)}" y no se puede modificar.`;
        readonlyNotice.classList.remove("hidden");
      } else {
        setTimeout(() => byId<HTMLTextAreaElement>("draft-content").focus(), 0);
      }
    }

    btnUpload.addEventListener("click", async () => {
      const fileInput = byId<HTMLInputElement>("draft-media-file");
      const file = fileInput.files?.[0];
      if (!file) {
        showError("Selecciona un archivo primero.");
        return;
      }

      btnUpload.disabled = true;
      btnUpload.textContent = "Subiendo…";
      hideAll();

      try {
        const form = new FormData();
        form.append("file", file);
        const res = await fetch(`${API}/drafts/${draftId}/upload-media`, {
          method: "POST",
          body: form,
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        fileInput.value = "";
        showSuccess("Archivo subido correctamente.");
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btnUpload.disabled = false;
        btnUpload.textContent = "Subir archivo";
      }
    });

    btnSchedule.addEventListener("click", async () => {
      const raw = scheduleInput.value;
      if (!raw) {
        showError("Elige primero fecha y hora.");
        return;
      }
      const iso = new Date(raw).toISOString();

      btnSchedule.disabled = true;
      btnSchedule.textContent = "Programando…";
      hideAll();

      try {
        const res = await fetch(`${API}/drafts/${draftId}/schedule`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ scheduled_at: iso }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        showSuccess("Borrador programado.");
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btnSchedule.disabled = false;
        btnSchedule.textContent = "Programar";
      }
    });

    btnUnschedule.addEventListener("click", async () => {
      btnUnschedule.disabled = true;
      btnUnschedule.textContent = "Quitando…";
      hideAll();

      try {
        const res = await fetch(`${API}/drafts/${draftId}/unschedule`, { method: "POST" });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        showSuccess("Programación quitada.");
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btnUnschedule.disabled = false;
        btnUnschedule.textContent = "Quitar programación";
      }
    });

    btnSave.addEventListener("click", async () => {
      const content = byId<HTMLTextAreaElement>("draft-content").value;
      const mediaUrlsRaw = byId<HTMLTextAreaElement>("draft-media-urls").value;
      const mediaUrls = mediaUrlsRaw.split("\n").map((s) => s.trim()).filter(Boolean);

      btnSave.disabled = true;
      btnSave.textContent = "Guardando…";
      hideAll();

      try {
        const body: { content: string; media_urls?: string[] } = { content };
        if (mediaUrls.length) body.media_urls = mediaUrls;
        const res = await fetch(`${API}/drafts/${draftId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Borrador actualizado correctamente.");
        btnSave.textContent = "¡Guardado!";
        setTimeout(() => {
          window.location.href = "/drafts";
        }, 1000);
      } catch (e) {
        showError("Error: " + (e as Error).message);
        btnSave.disabled = false;
        btnSave.textContent = "Guardar cambios";
      }
    });

    load();
  </script>
</Layout>
