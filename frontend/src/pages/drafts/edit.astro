---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
---

<Layout title="Edit Draft">
  <Nav />
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/drafts" class="link link-hover text-sm text-base-content/50">&larr; Back to drafts</a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Edit Draft</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/40">Loading draft...</span>
    </div>

    <div id="form-container" class="hidden">
      <div id="readonly-notice" class="alert alert-info mb-4 hidden">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        <span id="readonly-msg"></span>
      </div>

      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Draft details</legend>

        <label class="label">Status</label>
        <div id="draft-status-display"></div>

        <label class="label">Platform</label>
        <input type="text" id="draft-platform" class="input w-full" disabled />

        <label class="label">Idea ID</label>
        <input type="text" id="draft-idea-id" class="input w-full" disabled />

        <label class="label">Content</label>
        <textarea id="draft-content" class="textarea w-full h-48" placeholder="Draft content..."></textarea>

        <label class="label">Media URLs (one per line)</label>
        <textarea id="draft-media-urls" class="textarea w-full h-20" placeholder="https://example.com/image1.jpg"></textarea>

        <label class="label">Local files</label>
        <div id="draft-media-paths" class="text-sm text-base-content/60"></div>

        <div id="draft-upload-section">
          <label class="label">Upload new file</label>
          <input type="file" id="draft-media-file" accept="image/*" class="file-input file-input-bordered w-full" />
        </div>

        <label class="label">Schedule</label>
        <div id="draft-schedule-display" class="text-sm text-base-content/60 mb-2"></div>
        <div class="flex items-center gap-2 flex-wrap">
          <input type="datetime-local" id="draft-scheduled-at" class="input input-sm w-auto" />
          <button class="btn btn-sm btn-primary" id="btn-schedule">Set schedule</button>
          <button class="btn btn-sm btn-ghost" id="btn-unschedule">Remove schedule</button>
        </div>

        <label class="label">Notes</label>
        <div id="draft-notes" class="text-sm text-base-content/60"></div>

        <label class="label">Created</label>
        <div id="draft-created" class="text-sm text-base-content/60"></div>
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/drafts" class="btn">Cancel</a>
        <button class="btn" id="btn-upload-file">Upload file</button>
        <button class="btn btn-primary" id="btn-save">Save changes</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Draft not found.</div>
      <a href="/drafts" class="btn btn-ghost mt-4">&larr; Back to drafts</a>
    </div>
  </main>

  <script>
    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const draftId = params.get("id");

    const errorEl = document.getElementById("error-msg");
    const successEl = document.getElementById("success-msg");
    const loadingEl = document.getElementById("loading");
    const formContainer = document.getElementById("form-container");
    const notFoundEl = document.getElementById("not-found");
    const readonlyNotice = document.getElementById("readonly-notice");
    const readonlyMsg = document.getElementById("readonly-msg");
    const btnSave = document.getElementById("btn-save");
    const btnUpload = document.getElementById("btn-upload-file");
    const btnSchedule = document.getElementById("btn-schedule");
    const btnUnschedule = document.getElementById("btn-unschedule");
    const scheduleInput = document.getElementById("draft-scheduled-at");
    const uploadSection = document.getElementById("draft-upload-section");
    const editableInputs = ["draft-content", "draft-media-urls"].map(id => document.getElementById(id));

    const READONLY_STATUSES = ["approved", "rejected", "published", "failed"];

    function setFormEditable(editable) {
      editableInputs.forEach(el => { el.disabled = !editable; el.readOnly = !editable; });
      if (editable) {
        readonlyNotice.classList.add("hidden");
        btnSave.classList.remove("hidden");
        btnUpload.classList.remove("hidden");
        uploadSection.classList.remove("hidden");
      } else {
        btnSave.classList.add("hidden");
        btnUpload.classList.add("hidden");
        uploadSection.classList.add("hidden");
      }
    }

    function setStatusBadge(status) {
      const colors = { draft: "badge-warning", approved: "badge-info", rejected: "badge-error", published: "badge-success", failed: "badge-error" };
      return `<span class="badge badge-md badge-soft ${colors[status] || "badge-ghost"}">${status}</span>`;
    }

    function showError(msg) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    async function getErrorMessage(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    function esc(str) {
      if (!str) return "";
      const d = document.createElement("div");
      d.appendChild(document.createTextNode(str));
      return d.innerHTML;
    }

    function updateMediaPathsDisplay(paths) {
      const container = document.getElementById("draft-media-paths");
      if (!paths || !paths.length) {
        container.innerHTML = '<span class="text-base-content/40">No local files</span>';
        return;
      }
      container.innerHTML = paths.map(p =>
        `<div class="flex items-center gap-2"><span class="badge badge-sm badge-soft badge-info">file</span> ${esc(p.split("/").pop())}</div>`
      ).join("");
    }

    function toLocalInputValue(iso) {
      if (!iso) return "";
      const d = new Date(iso);
      if (isNaN(d.getTime())) return "";
      const pad = n => String(n).padStart(2, "0");
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function updateScheduleDisplay(scheduledAt, status) {
      const display = document.getElementById("draft-schedule-display");
      const published = status === "published";
      if (scheduledAt) {
        display.innerHTML = `<span class="badge badge-sm badge-soft badge-secondary"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ${new Date(scheduledAt).toLocaleString()}</span>`;
      } else {
        display.innerHTML = '<span class="text-base-content/40">Not scheduled</span>';
      }
      scheduleInput.value = toLocalInputValue(scheduledAt);
      scheduleInput.disabled = published;
      btnSchedule.disabled = published;
      btnUnschedule.disabled = published || !scheduledAt;
    }

    async function load() {
      if (!draftId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/drafts/${draftId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const draft = await res.json();
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      document.getElementById("page-title").textContent = `Edit: ${draft.platform} draft`;
      document.getElementById("draft-status-display").innerHTML = setStatusBadge(draft.status);
      document.getElementById("draft-platform").value = draft.platform;
      document.getElementById("draft-idea-id").value = draft.idea_id || "";
      document.getElementById("draft-content").value = draft.content;
      document.getElementById("draft-media-urls").value = (draft.media_urls || []).join("\n");
      updateMediaPathsDisplay(draft.media_paths);
      updateScheduleDisplay(draft.scheduled_at, draft.status);
      document.getElementById("draft-notes").textContent = draft.notes || "—";
      document.getElementById("draft-created").textContent = draft.created_at ? new Date(draft.created_at).toLocaleString() : "—";

      const readOnly = READONLY_STATUSES.includes(draft.status);
      setFormEditable(!readOnly);
      if (readOnly) {
        readonlyMsg.textContent = `This draft is in "${draft.status}" state and cannot be modified.`;
        readonlyNotice.classList.remove("hidden");
      }
    }

    btnUpload.addEventListener("click", async () => {
      const fileInput = document.getElementById("draft-media-file");
      const file = fileInput.files?.[0];
      if (!file) { showError("Select a file first."); return; }

      btnUpload.disabled = true;
      btnUpload.textContent = "Uploading...";
      hideAll();

      try {
        const form = new FormData();
        form.append("file", file);
        const res = await fetch(`${API}/drafts/${draftId}/upload-media`, {
          method: "POST",
          body: form,
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        fileInput.value = "";
        showSuccess("File uploaded successfully.");
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btnUpload.disabled = false;
        btnUpload.textContent = "Upload file";
      }
    });

    btnSchedule.addEventListener("click", async () => {
      const raw = scheduleInput.value;
      if (!raw) { showError("Pick a date and time first."); return; }
      const iso = new Date(raw).toISOString();

      btnSchedule.disabled = true;
      btnSchedule.textContent = "Scheduling...";
      hideAll();

      try {
        const res = await fetch(`${API}/drafts/${draftId}/schedule`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ scheduled_at: iso }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        showSuccess("Draft scheduled.");
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btnSchedule.disabled = false;
        btnSchedule.textContent = "Set schedule";
      }
    });

    btnUnschedule.addEventListener("click", async () => {
      btnUnschedule.disabled = true;
      btnUnschedule.textContent = "Removing...";
      hideAll();

      try {
        const res = await fetch(`${API}/drafts/${draftId}/unschedule`, { method: "POST" });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        showSuccess("Schedule removed.");
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btnUnschedule.disabled = false;
        btnUnschedule.textContent = "Remove schedule";
      }
    });

    btnSave.addEventListener("click", async () => {
      const content = document.getElementById("draft-content").value;
      const mediaUrlsRaw = document.getElementById("draft-media-urls").value;
      const mediaUrls = mediaUrlsRaw.split("\n").map(s => s.trim()).filter(Boolean);

      btnSave.disabled = true;
      btnSave.textContent = "Saving...";
      hideAll();

      try {
        const body = { content };
        if (mediaUrls.length) body.media_urls = mediaUrls;
        const res = await fetch(`${API}/drafts/${draftId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Draft updated successfully.");
        btnSave.textContent = "Saved!";
        setTimeout(() => { window.location.href = "/drafts"; }, 1000);
      } catch (e) {
        showError("Error: " + e.message);
        btnSave.disabled = false;
        btnSave.textContent = "Save changes";
      }
    });

    load();
  </script>
</Layout>
