---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Seeds">
  <Nav />
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">Seeds</h1>
      <button class="btn btn-primary" id="btn-generate">Generate from sources</button>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="seeds-list"><span class="loading loading-spinner loading-sm"></span> <span class="text-sm text-base-content/40">Loading...</span></div>
  </main>

  <dialog id="generate-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generate Seeds</legend>
        <label class="label">Interests</label>
        <textarea id="interests" class="textarea w-full" rows="4">soberanía digital, ética digital, pedagogía digital</textarea>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="gen-cancel">Cancel</button>
        <button class="btn btn-primary" id="gen-generate">Generate</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    const API = "http://localhost:8000/api";

    const errorEl = document.getElementById("error-msg");

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    async function getErrorMessage(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    async function load() {
      hideError();
      const res = await fetch(`${API}/seeds`);
      const seeds = await res.json();
      const container = document.getElementById("seeds-list");

      if (!seeds.length) {
        container.innerHTML = '<div class="alert bg-base-200 text-sm">No seeds yet. Click "Generate from sources" to create some.</div>';
        return;
      }

      container.innerHTML = `<ul class="list bg-base-100 border border-base-300 rounded-box divide-y divide-base-200">
        ${seeds.map(s => {
          const domain = s.source_url ? (() => { try { return new URL(s.source_url).hostname; } catch { return s.source_url; } })() : null;
          return `
          <li class="list-row items-center gap-3 py-3">
            <div class="min-w-0 flex-1 max-w-[75%]">
              <div class="font-medium">${esc(s.title)}</div>
              <div class="text-xs text-base-content/40 mb-1">${esc(s.summary)}</div>
              ${s.source_url
                ? `<div class="flex items-center gap-1 text-sm text-base-content/50">
                    <a href="${esc(s.source_url)}" target="_blank" rel="noopener noreferrer" class="truncate max-w-[200px] hover:text-primary transition-colors" title="${esc(s.source_url)}">${esc(domain)}</a>
                    <button class="btn btn-square btn-ghost btn-xs" data-action="copy-url" data-url="${esc(s.source_url)}" aria-label="Copy URL"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                  </div>`
                : ''}
            </div>
            <div class="flex items-center gap-2 shrink-0 ml-auto">
              <span class="badge badge-md badge-soft whitespace-nowrap ${s.status === "pending" ? "badge-warning" : s.status === "used" ? "badge-success" : "badge-error"}">${s.status}</span>
              <span class="text-sm text-base-content/40 whitespace-nowrap">${s.created_at ? new Date(s.created_at).toLocaleDateString() : "—"}</span>
              <div class="flex gap-1">${s.status === "pending"
                ? `<a href="/seeds/edit?id=${s.id}" class="btn btn-square btn-ghost btn-sm" aria-label="Edit seed"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></a><button class="btn btn-square btn-ghost btn-sm text-error" data-action="discard" data-id="${s.id}" aria-label="Discard seed"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`
                : `<a href="/seeds/edit?id=${s.id}" class="btn btn-square btn-ghost btn-sm btn-disabled" tabindex="-1" aria-disabled="true" aria-label="Edit seed"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></a><button class="btn btn-square btn-ghost btn-sm btn-disabled" tabindex="-1" aria-disabled="true" aria-label="Discard seed"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>`}</div>
            </div>
          </li>`}).join("")}
      </ul>`;
    }

    function esc(str) {
      if (!str) return "";
      const d = document.createElement("div");
      d.appendChild(document.createTextNode(str));
      return d.innerHTML;
    }

    document.getElementById("seeds-list").addEventListener("click", async (e) => {
      const btn = e.target.closest("[data-action]");
      if (!btn) return;
      hideError();
      const id = btn.dataset.id;

      try {
        if (btn.dataset.action === "discard") {
          const res = await fetch(`${API}/seeds/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: "discarded" }),
          });
          if (!res.ok) throw new Error(await getErrorMessage(res));
          load();
        } else if (btn.dataset.action === "copy-url") {
          try {
            await navigator.clipboard.writeText(btn.dataset.url);
            const original = btn.innerHTML;
            btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            btn.classList.add("text-success");
            setTimeout(() => {
              btn.innerHTML = original;
              btn.classList.remove("text-success");
            }, 1500);
          } catch {
            showError("Failed to copy URL");
          }
        }
      } catch (e) {
        showError("Error: " + e.message);
      }
    });

    document.getElementById("btn-generate").addEventListener("click", () => {
      hideError();
      document.getElementById("generate-modal").showModal();
    });

    document.getElementById("gen-cancel").addEventListener("click", () => {
      document.getElementById("generate-modal").close();
    });

    document.getElementById("gen-generate").addEventListener("click", async () => {
      const interests = document.getElementById("interests").value;
      if (!interests.trim()) { showError("Please enter interests."); return; }

      const btn = document.getElementById("gen-generate");
      btn.disabled = true;
      btn.textContent = "Generating...";
      hideError();

      try {
        const res = await fetch(`${API}/seeds/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ interests }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        document.getElementById("generate-modal").close();
        load();
      } catch (e) {
        showError("Error: " + e.message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generate";
      }
    });

    load();
  </script>
</Layout>
