---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Icon from "../components/Icon.astro";
---

<Layout title="Semillas">
  <Nav />
  <main id="main" class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 gap-2 flex-wrap">
      <h1 class="text-2xl font-bold">Semillas</h1>
      <div class="flex gap-2 flex-wrap">
        <button class="btn btn-primary gap-1.5" id="btn-add-article">
          <Icon name="plus" size={16} /> Añadir artículo
        </button>
        <button class="btn btn-outline gap-1.5" id="btn-generate-interests">
          <Icon name="sparkles" size={16} /> Generar desde intereses
        </button>
        <button class="btn btn-outline gap-1.5" id="btn-generate-sources">
          <Icon name="database" size={16} /> Generar desde fuentes
        </button>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>

    <div id="filters-bar" class="flex items-center gap-2 flex-wrap mb-4">
      <details class="dropdown">
        <summary class="btn btn-sm btn-outline gap-1.5">
          <Icon name="sliders" size={14} /> Añadir filtro
        </summary>
        <ul class="dropdown-content menu bg-base-100 border border-base-300 rounded-box z-10 w-48 p-2 shadow-sm">
          <li><button data-add-filter="status">Estado</button></li>
          <li><button data-add-filter="keyword">Palabra clave</button></li>
          <li><button data-add-filter="url">URL</button></li>
        </ul>
      </details>
      <div id="active-filters" class="flex items-center gap-2 flex-wrap"></div>
    </div>

    <div id="seeds-list">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando…</span>
    </div>
  </main>

  <dialog id="interests-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generar desde intereses</legend>
        <p class="text-sm text-base-content/60 mb-2">
          Introduce palabras clave para buscar coincidencias en nombres y etiquetas de fuentes. Se
          generarán semillas desde las fuentes que coincidan.
        </p>
        <label class="label" for="interests-input">Intereses (separados por comas)</label>
        <textarea id="interests-input" class="textarea w-full" rows="4" placeholder="soberanía digital, ética digital, pedagogía digital"></textarea>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="interests-cancel">Cancelar</button>
        <button class="btn btn-primary" id="interests-generate">Generar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="sources-modal" class="modal">
    <div class="modal-box max-w-lg">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Generar desde fuentes</legend>
        <p class="text-sm text-base-content/60 mb-2">Selecciona las fuentes de las que recopilar.</p>
        <div id="sources-list-modal" class="max-h-64 overflow-y-auto space-y-2">
          <span class="loading loading-spinner loading-sm"></span>
        </div>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="sources-cancel">Cancelar</button>
        <button class="btn btn-primary" id="sources-generate" disabled>Generar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog id="add-article-modal" class="modal">
    <div class="modal-box max-w-2xl">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold">Añadir artículo</legend>
        <p class="text-sm text-base-content/60 mb-2">
          Pega una URL para extraer su contenido, o rellena los campos manualmente.
        </p>

        <label class="label" for="add-article-url">URL</label>
        <div class="flex gap-2">
          <input type="url" id="add-article-url" class="input flex-1" placeholder="https://…" />
          <button class="btn btn-outline shrink-0" id="add-article-fetch">Obtener</button>
        </div>

        <label class="label mt-2" for="add-article-title">Título</label>
        <input type="text" id="add-article-title" class="input w-full" placeholder="Título del artículo" />

        <label class="label mt-2" for="add-article-content">Contenido</label>
        <textarea id="add-article-content" class="textarea w-full" rows="10" placeholder="Contenido del artículo…"></textarea>

        <label class="label mt-2" for="add-article-tags">Etiquetas (separadas por comas)</label>
        <input type="text" id="add-article-tags" class="input w-full" placeholder="tech, ia, ética" />
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="add-article-cancel">Cancelar</button>
        <button class="btn btn-primary" id="add-article-save" disabled>Guardar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { icon } from "~/scripts/icons";
    import { byId, qAll, esc, escAttr, getErrorMessage } from "~/scripts/dom";
    import {
      entityCard,
      cardTitle,
      contextBadge,
      statusBadgeSoft,
      actionBtn,
      actionEdit,
      actionDisabled,
      metaChip,
      tagChips,
      urlRow,
      actionsWrap,
      metaWrap,
    } from "~/scripts/card";
    import type { ScrapeResult, Seed, Source } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const errorEl = byId("error-msg");

    const STATUS_ES: Record<string, string> = {
      pending: "pendiente",
      approved: "aprobado",
      used: "usado",
      discarded: "descartado",
    };
    const STATUS_COLORS: Record<string, string> = {
      pending: "badge-warning",
      approved: "badge-info",
      used: "badge-success",
      discarded: "badge-error",
    };

    function statusLabel(s: string) {
      return STATUS_ES[s] || s;
    }

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    async function load() {
      hideError();
      const params = new URLSearchParams();
      filters.statuses.forEach((s) => params.append("statuses", s));
      if (filters.q) params.set("q", filters.q);
      if (filters.url) params.set("url", filters.url);
      const qs = params.toString();
      const res = await fetch(`${API}/seeds${qs ? "?" + qs : ""}`);
      const seeds = (await res.json()) as Seed[];
      const container = byId("seeds-list");

      if (!seeds.length) {
        container.innerHTML =
          '<div class="alert bg-base-200 text-sm">Aún no hay semillas. Pulsa "Añadir artículo" para pegar una URL, o "Generar desde fuentes" para recopilar desde tus fuentes configuradas.</div>';
        return;
      }

      container.innerHTML = `<div class="flex flex-col gap-3">${seeds
        .map((s) => {
          const sourceName = s.source_name || "";
          const sourceBadge = sourceName
            ? contextBadge(null, sourceName, "Fuente")
            : "";
          const canAct = s.status === "pending";
          const actBtns = canAct
            ? actionBtn("approve", s.id, "check", "Aprobar semilla", "text-info") +
              actionBtn("discard", s.id, "close", "Descartar semilla", "text-error")
            : actionDisabled("check", "Aprobar semilla", `No disponible en estado ${statusLabel(s.status)}`) +
              actionDisabled("close", "Descartar semilla", `No disponible en estado ${statusLabel(s.status)}`);
          const head = `${cardTitle(s.title)}${statusBadgeSoft(
            statusLabel(s.status),
            STATUS_COLORS[s.status] || "badge-ghost"
          )}`;
          const body = `${s.content ? `<div class="line-clamp-2">${esc(s.content)}</div>` : ""}<div class="flex items-center gap-2 flex-wrap">${sourceBadge}<div class="flex-1 min-w-0">${s.source_url ? urlRow(s.source_url) : ""}</div>${tagChips(s.tags)}</div>`;
          const foot = `${metaWrap(
            metaChip("clock", s.created_at ? new Date(s.created_at).toLocaleDateString() : "—")
          )}${actionsWrap(actionEdit(`/seeds/edit?id=${s.id}`, "Editar semilla") + actBtns)}`;
          return entityCard({ head, body, foot });
        })
        .join("")}</div>`;
    }

    byId("seeds-list").addEventListener("click", async (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-action]");
      if (!btn) return;
      hideError();
      const id = btn.dataset.id ?? "";

      try {
        if (btn.dataset.action === "discard") {
          const res = await fetch(`${API}/seeds/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: "discarded" }),
          });
          if (!res.ok) throw new Error(await getErrorMessage(res));
          load();
        } else if (btn.dataset.action === "approve") {
          const res = await fetch(`${API}/seeds/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: "approved" }),
          });
          if (!res.ok) throw new Error(await getErrorMessage(res));
          load();
        } else if (btn.dataset.action === "copy-url") {
          try {
            await navigator.clipboard.writeText(btn.dataset.url ?? "");
            const original = btn.innerHTML;
            btn.innerHTML = icon("check", 14);
            btn.classList.add("text-success");
            setTimeout(() => {
              btn.innerHTML = original;
              btn.classList.remove("text-success");
            }, 1500);
          } catch {
            showError("No se pudo copiar la URL");
          }
        }
      } catch (e) {
        showError("Error: " + (e as Error).message);
      }
    });

    // ── Generar desde intereses ──

    byId("btn-generate-interests").addEventListener("click", () => {
      hideError();
      byId<HTMLTextAreaElement>("interests-input").value = "";
      byId<HTMLDialogElement>("interests-modal").showModal();
      setTimeout(() => byId<HTMLTextAreaElement>("interests-input").focus(), 0);
    });

    byId("interests-cancel").addEventListener("click", () => {
      byId<HTMLDialogElement>("interests-modal").close();
    });

    byId("interests-generate").addEventListener("click", async () => {
      const raw = byId<HTMLTextAreaElement>("interests-input").value.trim();
      if (!raw) {
        showError("Introduce al menos un interés.");
        return;
      }

      const keywords = raw.split(",").map((k) => k.trim().toLowerCase()).filter(Boolean);
      if (!keywords.length) {
        showError("Introduce al menos un interés.");
        return;
      }

      const btn = byId<HTMLButtonElement>("interests-generate");
      btn.disabled = true;
      btn.textContent = "Generando…";
      hideError();

      try {
        const sourcesRes = await fetch(`${API}/sources`);
        const sources = (await sourcesRes.json()) as Source[];

        const matchingIds = sources
          .filter(
            (s) =>
              s.enabled !== false &&
              (keywords.some((k) => s.name.toLowerCase().includes(k)) ||
                (s.tags || []).some((t) => keywords.some((k) => t.toLowerCase().includes(k))))
          )
          .map((s) => s.id);

        if (!matchingIds.length) {
          showError("Ninguna fuente coincide con tus intereses. Añade fuentes con etiquetas coincidentes primero.");
          btn.disabled = false;
          btn.textContent = "Generar";
          return;
        }

        const res = await fetch(`${API}/seeds/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ source_ids: matchingIds }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        byId<HTMLDialogElement>("interests-modal").close();
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generar";
      }
    });

    // ── Generar desde fuentes ──

    async function loadSourceCheckboxes() {
      try {
        const res = await fetch(`${API}/sources`);
        const sources = (await res.json()) as Source[];
        const container = byId("sources-list-modal");

        if (!sources.length) {
          container.innerHTML = '<div class="text-sm text-base-content/60">No hay fuentes configuradas.</div>';
          return;
        }

        container.innerHTML = sources
          .map(
            (s) => `
          <label class="flex items-center gap-3 p-2 rounded-box hover:bg-base-200 cursor-pointer ${s.enabled === false ? "opacity-40" : ""}">
            <input type="checkbox" class="checkbox checkbox-sm source-checkbox" data-id="${esc(s.id)}" ${s.enabled !== false ? "" : "disabled"} />
            <div class="min-w-0 flex-1">
              <div class="text-sm font-medium">${esc(s.name)}</div>
              <div class="text-xs text-base-content/60">${esc(s.source_type)} ${s.tags?.length ? "— " + s.tags.map((t) => esc(t)).join(", ") : ""}</div>
            </div>
          </label>`
          )
          .join("");

        qAll<HTMLInputElement>(".source-checkbox").forEach((cb) => {
          cb.addEventListener("change", updateSourcesGenerateButton);
        });
        updateSourcesGenerateButton();
      } catch {
        byId("sources-list-modal").innerHTML =
          '<div class="text-sm text-error">No se pudieron cargar las fuentes.</div>';
      }
    }

    function updateSourcesGenerateButton() {
      const checked = qAll<HTMLInputElement>(".source-checkbox:checked");
      byId<HTMLButtonElement>("sources-generate").disabled = checked.length === 0;
    }

    byId("btn-generate-sources").addEventListener("click", () => {
      hideError();
      byId("sources-list-modal").innerHTML =
        '<span class="loading loading-spinner loading-sm"></span>';
      loadSourceCheckboxes();
      byId<HTMLDialogElement>("sources-modal").showModal();
    });

    byId("sources-cancel").addEventListener("click", () => {
      byId<HTMLDialogElement>("sources-modal").close();
    });

    byId("sources-generate").addEventListener("click", async () => {
      const sourceIds = qAll<HTMLInputElement>(".source-checkbox:checked")
        .map((cb) => cb.dataset.id ?? "")
        .filter(Boolean);

      if (!sourceIds.length) {
        showError("Selecciona al menos una fuente.");
        return;
      }

      const btn = byId<HTMLButtonElement>("sources-generate");
      btn.disabled = true;
      btn.textContent = "Generando…";
      hideError();

      try {
        const res = await fetch(`${API}/seeds/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ source_ids: sourceIds }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        byId<HTMLDialogElement>("sources-modal").close();
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btn.disabled = false;
        btn.textContent = "Generar";
      }
    });

    // ── Añadir artículo ──

    const addModal = byId<HTMLDialogElement>("add-article-modal");
    const addUrlInput = byId<HTMLInputElement>("add-article-url");
    const addTitleInput = byId<HTMLInputElement>("add-article-title");
    const addContentInput = byId<HTMLTextAreaElement>("add-article-content");
    const addTagsInput = byId<HTMLInputElement>("add-article-tags");
    const addFetchBtn = byId<HTMLButtonElement>("add-article-fetch");
    const addSaveBtn = byId<HTMLButtonElement>("add-article-save");

    function updateAddSaveButton() {
      addSaveBtn.disabled = !addUrlInput.value.trim() || !addTitleInput.value.trim();
    }

    addUrlInput.addEventListener("input", updateAddSaveButton);
    addTitleInput.addEventListener("input", updateAddSaveButton);

    byId("btn-add-article").addEventListener("click", () => {
      hideError();
      addUrlInput.value = "";
      addTitleInput.value = "";
      addContentInput.value = "";
      addTagsInput.value = "";
      addFetchBtn.disabled = false;
      addFetchBtn.textContent = "Obtener";
      addSaveBtn.disabled = true;
      addModal.showModal();
      setTimeout(() => addUrlInput.focus(), 0);
    });

    byId("add-article-cancel").addEventListener("click", () => {
      addModal.close();
    });

    addFetchBtn.addEventListener("click", async () => {
      const url = addUrlInput.value.trim();
      if (!url) {
        showError("Introduce una URL primero.");
        return;
      }

      addFetchBtn.disabled = true;
      addFetchBtn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Obteniendo…';
      hideError();

      try {
        const res = await fetch(`${API}/seeds/scrape`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));
        const data = (await res.json()) as ScrapeResult;
        if (data.title) addTitleInput.value = data.title;
        if (data.content) addContentInput.value = data.content;
        updateAddSaveButton();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        addFetchBtn.disabled = false;
        addFetchBtn.textContent = "Obtener";
      }
    });

    addSaveBtn.addEventListener("click", async () => {
      const url = addUrlInput.value.trim();
      const title = addTitleInput.value.trim();
      const content = addContentInput.value.trim();
      const tags = addTagsInput.value.split(",").map((t) => t.trim()).filter(Boolean);

      if (!url || !title) {
        showError("La URL y el título son obligatorios.");
        return;
      }

      addSaveBtn.disabled = true;
      addSaveBtn.textContent = "Guardando…";
      hideError();

      try {
        const res = await fetch(`${API}/seeds`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url, title, content, tags, scrape: false }),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        addModal.close();
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        addSaveBtn.disabled = false;
        addSaveBtn.textContent = "Guardar";
      }
    });

    // ── Filtros ──

    const ALL_STATUSES = ["pending", "approved", "used", "discarded"];
    const STATUS_LABELS: Record<string, string> = {
      pending: "warning",
      approved: "info",
      used: "success",
      discarded: "error",
    };

    const filters = { statuses: [] as string[], q: "", url: "" };
    const activeTypes = new Set<string>();

    function renderFilters() {
      const container = byId("active-filters");
      container.innerHTML = "";

      if (activeTypes.has("status")) {
        const checked = new Set(filters.statuses);
        const checkboxes = ALL_STATUSES.map(
          (st) => `
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-xs" data-status="${st}" ${checked.has(st) ? "checked" : ""} />
            <span class="badge badge-sm badge-soft badge-${STATUS_LABELS[st]}">${statusLabel(st)}</span>
          </label>`
        ).join("");
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Estado</span>
            <div class="flex items-center gap-1.5 flex-wrap">${checkboxes}</div>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="status" aria-label="Quitar filtro de estado" title="Quitar filtro de estado">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("keyword")) {
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Palabra clave</span>
            <input type="text" class="input input-xs w-40" id="filter-q" placeholder="buscar contenido" value="${escAttr(filters.q)}" />
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="keyword" aria-label="Quitar filtro de palabra clave" title="Quitar filtro de palabra clave">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("url")) {
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">URL</span>
            <input type="text" class="input input-xs w-40" id="filter-url" placeholder="fragmento de url" value="${escAttr(filters.url)}" />
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="url" aria-label="Quitar filtro de URL" title="Quitar filtro de URL">${icon("close", 14)}</button>
          </div>`;
      }

      updateAddFilterMenu();
      bindFilterEvents();
    }

    function updateAddFilterMenu() {
      qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
        const type = btn.dataset.addFilter ?? "";
        const li = btn.closest("li");
        if (!li) return;
        if (activeTypes.has(type)) {
          li.classList.add("hidden");
        } else {
          li.classList.remove("hidden");
        }
      });
    }

    function bindFilterEvents() {
      qAll<HTMLButtonElement>("[data-remove-filter]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.removeFilter ?? "";
          activeTypes.delete(type);
          if (type === "status") filters.statuses = [];
          if (type === "keyword") filters.q = "";
          if (type === "url") filters.url = "";
          renderFilters();
          load();
        });
      });

      qAll<HTMLInputElement>("[data-status]").forEach((cb) => {
        cb.addEventListener("change", () => {
          filters.statuses = qAll<HTMLInputElement>("[data-status]:checked")
            .map((el) => el.dataset.status ?? "")
            .filter(Boolean);
          load();
        });
      });

      const qInput = byId<HTMLInputElement>("filter-q");
      if (qInput) {
        qInput.addEventListener("input", () => {
          filters.q = qInput.value;
          clearTimeout(qInput._t);
          qInput._t = setTimeout(load, 300);
        });
      }

      const urlInput = byId<HTMLInputElement>("filter-url");
      if (urlInput) {
        urlInput.addEventListener("input", () => {
          filters.url = urlInput.value;
          clearTimeout(urlInput._t);
          urlInput._t = setTimeout(load, 300);
        });
      }
    }

    qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.dataset.addFilter ?? "";
        if (activeTypes.has(type)) return;
        activeTypes.add(type);
        const dropdown = btn.closest("details");
        if (dropdown) dropdown.open = false;
        renderFilters();
        load();
      });
    });

    load();
  </script>
</Layout>
