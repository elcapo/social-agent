---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Icon from "../../components/Icon.astro";
---

<Layout title="Editar semilla">
  <Nav />
  <main id="main" class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/seeds" class="link link-hover text-sm text-base-content/60 inline-flex items-center gap-1 no-underline">
          <Icon name="arrow-left" size={14} /> Volver a semillas
        </a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Editar semilla</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando semilla…</span>
    </div>

    <div id="form-container" class="hidden">
      <div id="readonly-notice" class="alert alert-info mb-4 hidden gap-2">
        <Icon name="info" size={20} />
        <span id="readonly-msg"></span>
      </div>

      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Detalles de la semilla</legend>

        <label class="label">Estado</label>
        <div id="seed-status-display"></div>

        <label class="label" for="seed-title">Título</label>
        <input type="text" id="seed-title" class="input w-full" placeholder="Título de la semilla" />

        <label class="label" for="seed-content">Contenido</label>
        <textarea id="seed-content" class="textarea w-full" rows="8" placeholder="Contenido de la semilla…"></textarea>

        <label class="label" for="seed-source-url">URL de origen</label>
        <input type="url" id="seed-source-url" class="input w-full" placeholder="https://…" />

        <label class="label">Creado</label>
        <div id="seed-created" class="text-sm text-base-content/60"></div>
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/seeds" class="btn">Cancelar</a>
        <button class="btn btn-primary" id="btn-save">Guardar cambios</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Semilla no encontrada.</div>
      <a href="/seeds" class="btn btn-ghost mt-4 gap-1.5">
        <Icon name="arrow-left" size={16} /> Volver a semillas
      </a>
    </div>
  </main>

  <script>
    import { byId, getErrorMessage } from "~/scripts/dom";
    import type { Seed } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const seedId = params.get("id");

    const errorEl = byId("error-msg");
    const successEl = byId("success-msg");
    const loadingEl = byId("loading");
    const formContainer = byId("form-container");
    const notFoundEl = byId("not-found");
    const readonlyNotice = byId("readonly-notice");
    const readonlyMsg = byId("readonly-msg");
    const btnSave = byId<HTMLButtonElement>("btn-save");
    const allInputs: (HTMLInputElement | HTMLTextAreaElement)[] = [
      byId<HTMLInputElement>("seed-title"),
      byId<HTMLTextAreaElement>("seed-content"),
      byId<HTMLInputElement>("seed-source-url"),
    ];

    const READONLY_STATUSES = ["approved", "used", "discarded"];
    const STATUS_ES: Record<string, string> = {
      pending: "pendiente",
      approved: "aprobado",
      used: "usado",
      discarded: "descartado",
    };
    const statusLabel = (s: string) => STATUS_ES[s] || s;

    function setFormEditable(editable: boolean) {
      allInputs.forEach((el) => {
        el.disabled = !editable;
        el.readOnly = !editable;
      });
      if (editable) {
        readonlyNotice.classList.add("hidden");
        btnSave.classList.remove("hidden");
      } else {
        btnSave.classList.add("hidden");
      }
    }

    function setStatusBadge(status: string) {
      const colors: Record<string, string> = {
        pending: "badge-warning",
        approved: "badge-info",
        used: "badge-success",
        discarded: "badge-error",
      };
      return `<span class="badge badge-md badge-soft ${colors[status] || "badge-ghost"}" title="Estado ${statusLabel(status)}">${statusLabel(status)}</span>`;
    }

    function showError(msg: string) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg: string) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    async function load() {
      if (!seedId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/seeds/${seedId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const seed = (await res.json()) as Seed;
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      byId("page-title").textContent = `Editar: ${seed.title}`;
      byId("seed-status-display").innerHTML = setStatusBadge(seed.status);
      byId<HTMLInputElement>("seed-title").value = seed.title;
      byId<HTMLTextAreaElement>("seed-content").value = seed.content || "";
      byId<HTMLInputElement>("seed-source-url").value = seed.source_url || "";
      byId("seed-created").textContent = seed.created_at
        ? new Date(seed.created_at).toLocaleString()
        : "—";

      const readOnly = READONLY_STATUSES.includes(seed.status);
      setFormEditable(!readOnly);
      if (readOnly) {
        readonlyMsg.textContent = `Esta semilla está en estado "${statusLabel(seed.status)}" y no se puede modificar.`;
        readonlyNotice.classList.remove("hidden");
      } else {
        setTimeout(() => byId<HTMLInputElement>("seed-title").focus(), 0);
      }
    }

    btnSave.addEventListener("click", async () => {
      const title = byId<HTMLInputElement>("seed-title").value.trim();
      const content = byId<HTMLTextAreaElement>("seed-content").value.trim();
      const sourceUrl = byId<HTMLInputElement>("seed-source-url").value.trim();

      if (!title) {
        showError("El título es obligatorio.");
        return;
      }

      btnSave.disabled = true;
      btnSave.textContent = "Guardando…";
      hideAll();

      try {
        const body: { title: string; content: string; source_url?: string } = { title, content };
        if (sourceUrl) body.source_url = sourceUrl;
        const res = await fetch(`${API}/seeds/${seedId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Semilla actualizada correctamente.");
        btnSave.textContent = "¡Guardado!";
        setTimeout(() => {
          window.location.href = "/seeds";
        }, 1000);
      } catch (e) {
        showError("Error: " + (e as Error).message);
        btnSave.disabled = false;
        btnSave.textContent = "Guardar cambios";
      }
    });

    load();
  </script>
</Layout>
