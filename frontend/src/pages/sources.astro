---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Icon from "../components/Icon.astro";
---

<Layout title="Fuentes">
  <Nav />
  <main id="main" class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 gap-2 flex-wrap">
      <h1 class="text-2xl font-bold">Fuentes</h1>
      <button class="btn btn-primary gap-1.5" id="btn-add">
        <Icon name="plus" size={16} /> Añadir fuente
      </button>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>

    <div id="filters-bar" class="flex items-center gap-2 flex-wrap mb-4">
      <details class="dropdown">
        <summary class="btn btn-sm btn-outline gap-1.5">
          <Icon name="sliders" size={14} /> Añadir filtro
        </summary>
        <ul class="dropdown-content menu bg-base-100 border border-base-300 rounded-box z-10 w-48 p-2 shadow-sm">
          <li><button data-add-filter="type">Tipo</button></li>
          <li><button data-add-filter="keyword">Palabra clave</button></li>
          <li><button data-add-filter="enabled">Estado activo</button></li>
        </ul>
      </details>
      <div id="active-filters" class="flex items-center gap-2 flex-wrap"></div>
    </div>

    <div id="sources-list">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/60">Cargando…</span>
    </div>
  </main>

  <dialog id="form-modal" class="modal">
    <div class="modal-box">
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xl font-bold" id="form-title">Añadir fuente</legend>
        <label class="label" for="src-name">Nombre</label>
        <input type="text" id="src-name" class="input w-full" placeholder="Mi feed RSS" />
        <label class="label" for="src-type">Tipo</label>
        <select id="src-type" class="select w-full">
          <option value="rss">RSS</option>
          <option value="webpage">Página web</option>
          <option value="link_scraper">Scraper de enlaces</option>
          <option value="social">Social</option>
          <option value="manual">Manual</option>
        </select>
        <label class="label" for="src-url">URL</label>
        <input type="url" id="src-url" class="input w-full" placeholder="https://…" />
        <label class="label" for="src-priority">Prioridad</label>
        <select id="src-priority" class="select w-full">
          <option value="1">Alta (1)</option>
          <option value="2" selected>Media (2)</option>
          <option value="3">Baja (3)</option>
        </select>
        <label class="label" for="src-tags">Etiquetas (separadas por comas)</label>
        <input type="text" id="src-tags" class="input w-full" placeholder="tech, python" />
        <div id="config-field">
          <label class="label" for="src-config">Configuración (JSON)</label>
          <textarea id="src-config" class="textarea w-full font-mono text-sm" rows="3" placeholder='{"url_pattern": "/blog/.+", "max_items": 10}'></textarea>
        </div>
      </fieldset>
      <div class="modal-action">
        <button class="btn" id="modal-cancel">Cancelar</button>
        <button class="btn btn-primary" id="modal-save">Guardar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { icon } from "~/scripts/icons";
    import { byId, qAll, escAttr, getErrorMessage } from "~/scripts/dom";
    import {
      entityCard,
      cardTitle,
      contextBadge,
      statusBadgeSoft,
      actionBtn,
      actionEdit,
      metaChip,
      tagChips,
      urlRow,
      actionsWrap,
      metaWrap,
    } from "~/scripts/card";
    import type { Source } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    const errorEl = byId("error-msg");

    const TYPE_ICONS: Record<string, string> = {
      rss: "rss",
      webpage: "globe",
      link_scraper: "link",
      social: "users",
      manual: "type",
    };

    const PRIORITY_LABELS: Record<string, string> = {
      "1": "Alta",
      "2": "Media",
      "3": "Baja",
    };

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function hideError() {
      errorEl.classList.add("hidden");
    }

    async function load() {
      hideError();
      const params = new URLSearchParams();
      filters.types.forEach((t) => params.append("source_types", t));
      if (filters.q) params.set("q", filters.q);
      if (filters.enabled !== null) params.set("enabled", String(filters.enabled));
      const qs = params.toString();
      const res = await fetch(`${API}/sources${qs ? "?" + qs : ""}`);
      const sources = ((await res.json()) as Source[]).sort(
        (a, b) => (a.priority ?? 2) - (b.priority ?? 2)
      );
      const container = byId("sources-list");

      if (!sources.length) {
        container.innerHTML =
          '<div class="alert bg-base-200 text-sm">No hay fuentes configuradas. Añade una para empezar.</div>';
        return;
      }

      container.innerHTML = `<div class="flex flex-col gap-3">${sources
        .map((s) => {
          const typeIconName = TYPE_ICONS[s.source_type] ?? null;
          const prio = PRIORITY_LABELS[String(s.priority)] || String(s.priority);
          const disabledBadge =
            s.enabled === false
              ? `<span class="badge badge-sm badge-soft badge-error shrink-0">desactivada</span>`
              : "";
          const head = `${cardTitle(s.name)}${disabledBadge}${statusBadgeSoft(s.enabled === false ? "desactivada" : "activa", s.enabled === false ? "badge-error" : "badge-success")}`;
          const body = `<div class="flex items-center gap-2 flex-wrap">${contextBadge(typeIconName, s.source_type, "Tipo de fuente")}<div class="flex-1 min-w-0">${urlRow(s.url)}</div>${tagChips(s.tags)}</div>`;
          const foot = `${metaWrap(
            metaChip("info", `Prioridad ${prio}`, `Prioridad ${prio} (${s.priority})`) +
              metaChip("clock", s.created_at ? new Date(s.created_at).toLocaleDateString() : "—")
          )}${actionsWrap(
            actionEdit(`/sources/edit?id=${s.id}`, "Editar fuente") +
              actionBtn("delete", s.id, "trash", "Eliminar fuente", "text-error")
          )}`;
          return entityCard({ head, body, foot });
        })
        .join("")}</div>`;
    }

    function openAddForm() {
      byId("form-title").textContent = "Añadir fuente";
      byId("modal-save").textContent = "Guardar";
      byId<HTMLInputElement>("src-name").value = "";
      byId<HTMLSelectElement>("src-type").value = "rss";
      byId<HTMLInputElement>("src-url").value = "";
      byId<HTMLSelectElement>("src-priority").value = "2";
      byId<HTMLInputElement>("src-tags").value = "";
      byId<HTMLTextAreaElement>("src-config").value = "";
      byId<HTMLTextAreaElement>("src-config").placeholder = '{"full_content": true}';
      byId<HTMLDialogElement>("form-modal").showModal();
      setTimeout(() => byId<HTMLInputElement>("src-name").focus(), 0);
    }

    byId<HTMLSelectElement>("src-type").addEventListener("change", () => {
      const type = byId<HTMLSelectElement>("src-type").value;
      const placeholder =
        type === "rss"
          ? '{"full_content": true}'
          : type === "link_scraper"
            ? '{"url_pattern": "/blog/.+", "max_items": 10}'
            : '{"key": "value"}';
      byId<HTMLTextAreaElement>("src-config").placeholder = placeholder;
    });

    byId("sources-list").addEventListener("click", async (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-action]");
      if (!btn) return;
      hideError();

      if (btn.dataset.action === "delete") {
        const id = btn.dataset.id ?? "";
        const res = await fetch(`${API}/sources/${id}`, { method: "DELETE" });
        if (!res.ok) {
          showError("No se pudo eliminar la fuente");
          return;
        }
        load();
      } else if (btn.dataset.action === "copy-url") {
        try {
          await navigator.clipboard.writeText(btn.dataset.url ?? "");
          const original = btn.innerHTML;
          btn.innerHTML = icon("check", 14);
          btn.classList.add("text-success");
          setTimeout(() => {
            btn.innerHTML = original;
            btn.classList.remove("text-success");
          }, 1500);
        } catch {
          showError("No se pudo copiar la URL");
        }
      }
    });

    byId("btn-add").addEventListener("click", () => {
      hideError();
      openAddForm();
    });

    byId("modal-cancel").addEventListener("click", () => {
      byId<HTMLDialogElement>("form-modal").close();
    });

    byId("modal-save").addEventListener("click", async () => {
      const name = byId<HTMLInputElement>("src-name").value.trim();
      const sourceType = byId<HTMLSelectElement>("src-type").value;
      const url = byId<HTMLInputElement>("src-url").value.trim();
      const priority = parseInt(byId<HTMLSelectElement>("src-priority").value);
      const tagsStr = byId<HTMLInputElement>("src-tags").value.trim();

      if (!name || !url) {
        showError("El nombre y la URL son obligatorios.");
        return;
      }

      const btn = byId<HTMLButtonElement>("modal-save");
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Guardando…";
      hideError();

      try {
        const tagList = tagsStr ? tagsStr.split(",").map((t) => t.trim()) : [];
        const params = new URLSearchParams({
          name,
          source_type: sourceType,
          url,
          priority: String(priority),
        });
        tagList.forEach((t) => params.append("tags", t));
        const configVal = byId<HTMLTextAreaElement>("src-config").value.trim();
        if (configVal) {
          try {
            JSON.parse(configVal);
            params.append("config", configVal);
          } catch {
            showError("La configuración no es JSON válido.");
            btn.disabled = false;
            btn.textContent = original;
            return;
          }
        }
        const res = await fetch(`${API}/sources?${params}`, { method: "POST" });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        byId<HTMLDialogElement>("form-modal").close();
        ["src-name", "src-url", "src-tags"].forEach(
          (id) => (byId<HTMLInputElement>(id).value = "")
        );
        load();
      } catch (e) {
        showError("Error: " + (e as Error).message);
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });

    // ── Filtros ──

    const ALL_TYPES = ["rss", "webpage", "link_scraper", "social", "manual"];

    const filters = { types: [] as string[], q: "", enabled: null as boolean | null };
    const activeTypes = new Set<string>();

    function renderFilters() {
      const container = byId("active-filters");
      container.innerHTML = "";

      if (activeTypes.has("type")) {
        const checked = new Set(filters.types);
        const checkboxes = ALL_TYPES.map(
          (t) => `
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-xs" data-type="${t}" ${checked.has(t) ? "checked" : ""} />
            <span class="badge badge-sm badge-soft">${t}</span>
          </label>`
        ).join("");
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Tipo</span>
            <div class="flex items-center gap-1.5 flex-wrap">${checkboxes}</div>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="type" aria-label="Quitar filtro de tipo" title="Quitar filtro de tipo">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("keyword")) {
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Palabra clave</span>
            <input type="text" class="input input-xs w-40" id="filter-q" placeholder="buscar nombre, url, etiquetas" value="${escAttr(filters.q)}" />
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="keyword" aria-label="Quitar filtro de palabra clave" title="Quitar filtro de palabra clave">${icon("close", 14)}</button>
          </div>`;
      }

      if (activeTypes.has("enabled")) {
        const cur = filters.enabled === null ? "all" : filters.enabled ? "enabled" : "disabled";
        container.innerHTML += `
          <div class="flex items-center gap-2 px-3 py-1.5 bg-base-200 rounded-full">
            <span class="text-xs font-medium text-base-content/60">Estado activo</span>
            <select class="select select-xs" id="filter-enabled">
              <option value="all" ${cur === "all" ? "selected" : ""}>Todas</option>
              <option value="enabled" ${cur === "enabled" ? "selected" : ""}>Activadas</option>
              <option value="disabled" ${cur === "disabled" ? "selected" : ""}>Desactivadas</option>
            </select>
            <button class="btn btn-ghost btn-xs btn-circle" data-remove-filter="enabled" aria-label="Quitar filtro de estado activo" title="Quitar filtro de estado activo">${icon("close", 14)}</button>
          </div>`;
      }

      updateAddFilterMenu();
      bindFilterEvents();
    }

    function updateAddFilterMenu() {
      qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
        const type = btn.dataset.addFilter ?? "";
        const li = btn.closest("li");
        if (!li) return;
        if (activeTypes.has(type)) {
          li.classList.add("hidden");
        } else {
          li.classList.remove("hidden");
        }
      });
    }

    function bindFilterEvents() {
      qAll<HTMLButtonElement>("[data-remove-filter]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.removeFilter ?? "";
          activeTypes.delete(type);
          if (type === "type") filters.types = [];
          if (type === "keyword") filters.q = "";
          if (type === "enabled") filters.enabled = null;
          renderFilters();
          load();
        });
      });

      qAll<HTMLInputElement>("[data-type]").forEach((cb) => {
        cb.addEventListener("change", () => {
          filters.types = qAll<HTMLInputElement>("[data-type]:checked")
            .map((el) => el.dataset.type ?? "")
            .filter(Boolean);
          load();
        });
      });

      const qInput = byId<HTMLInputElement>("filter-q");
      if (qInput) {
        qInput.addEventListener("input", () => {
          filters.q = qInput.value;
          clearTimeout(qInput._t);
          qInput._t = setTimeout(load, 300);
        });
      }

      const enabledSelect = byId<HTMLSelectElement>("filter-enabled");
      if (enabledSelect) {
        enabledSelect.addEventListener("change", () => {
          const v = enabledSelect.value;
          filters.enabled = v === "all" ? null : v === "enabled";
          load();
        });
      }
    }

    qAll<HTMLButtonElement>("[data-add-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.dataset.addFilter ?? "";
        if (activeTypes.has(type)) return;
        activeTypes.add(type);
        const dropdown = btn.closest("details");
        if (dropdown) dropdown.open = false;
        renderFilters();
        load();
      });
    });

    load();
  </script>
</Layout>
