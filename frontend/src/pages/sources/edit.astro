---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
---

<Layout title="Edit Source">
  <Nav />
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/sources" class="link link-hover text-sm text-base-content/50">&larr; Back to sources</a>
        <h1 class="text-2xl font-bold mt-1" id="page-title">Edit Source</h1>
      </div>
    </div>

    <div id="error-msg" class="alert alert-error mb-4 hidden"></div>
    <div id="success-msg" class="alert alert-success mb-4 hidden"></div>

    <div id="loading" class="flex items-center gap-2 py-8">
      <span class="loading loading-spinner loading-sm"></span>
      <span class="text-sm text-base-content/40">Loading source...</span>
    </div>

    <div id="form-container" class="hidden">
      <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-6">
        <legend class="fieldset-legend text-xl font-bold">Source details</legend>

        <label class="label">Name</label>
        <input type="text" id="src-name" class="input w-full" placeholder="My RSS feed" />

        <label class="label">Type</label>
        <select id="src-type" class="select w-full">
          <option value="rss">RSS</option>
          <option value="webpage">Webpage</option>
          <option value="social">Social</option>
          <option value="manual">Manual</option>
        </select>

        <label class="label">URL</label>
        <input type="url" id="src-url" class="input w-full" placeholder="https://..." />

        <label class="label">Priority</label>
        <select id="src-priority" class="select w-full">
          <option value="1">High (1)</option>
          <option value="2" selected>Medium (2)</option>
          <option value="3">Low (3)</option>
        </select>

        <label class="label">Tags (comma-separated)</label>
        <input type="text" id="src-tags" class="input w-full" placeholder="tech, python" />
      </fieldset>

      <div class="flex gap-3 mt-6">
        <a href="/sources" class="btn">Cancel</a>
        <button class="btn btn-primary" id="btn-save">Save changes</button>
      </div>
    </div>

    <div id="not-found" class="hidden">
      <div class="alert alert-error">Source not found.</div>
      <a href="/sources" class="btn btn-ghost mt-4">&larr; Back to sources</a>
    </div>
  </main>

  <script>
    const API = "http://localhost:8000/api";

    const params = new URLSearchParams(window.location.search);
    const sourceId = params.get("id");

    const errorEl = document.getElementById("error-msg");
    const successEl = document.getElementById("success-msg");
    const loadingEl = document.getElementById("loading");
    const formContainer = document.getElementById("form-container");
    const notFoundEl = document.getElementById("not-found");

    function showError(msg) {
      successEl.classList.add("hidden");
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }

    function showSuccess(msg) {
      errorEl.classList.add("hidden");
      successEl.textContent = msg;
      successEl.classList.remove("hidden");
    }

    function hideAll() {
      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");
    }

    async function getErrorMessage(res) {
      try {
        const body = await res.json();
        if (Array.isArray(body.detail)) return body.detail[0]?.msg || "Request failed";
        return body.detail || "Request failed";
      } catch { return "Request failed"; }
    }

    async function load() {
      if (!sourceId) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const res = await fetch(`${API}/sources/${sourceId}`);
      if (!res.ok) {
        loadingEl.classList.add("hidden");
        notFoundEl.classList.remove("hidden");
        return;
      }

      const source = await res.json();
      loadingEl.classList.add("hidden");
      formContainer.classList.remove("hidden");

      document.getElementById("page-title").textContent = `Edit: ${source.name}`;
      document.getElementById("src-name").value = source.name;
      document.getElementById("src-type").value = source.source_type;
      document.getElementById("src-url").value = source.url;
      document.getElementById("src-priority").value = String(source.priority);
      document.getElementById("src-tags").value = (source.tags || []).join(", ");
    }

    document.getElementById("btn-save").addEventListener("click", async () => {
      const name = document.getElementById("src-name").value.trim();
      const sourceType = document.getElementById("src-type").value;
      const url = document.getElementById("src-url").value.trim();
      const priority = parseInt(document.getElementById("src-priority").value);
      const tagsStr = document.getElementById("src-tags").value.trim();

      if (!name || !url) { showError("Name and URL are required."); return; }

      const btn = document.getElementById("btn-save");
      btn.disabled = true;
      btn.textContent = "Saving...";
      hideAll();

      try {
        const tagList = tagsStr ? tagsStr.split(",").map(t => t.trim()) : [];
        const params = new URLSearchParams({ name, source_type: sourceType, url, priority: String(priority) });
        tagList.forEach(t => params.append("tags", t));
        const res = await fetch(`${API}/sources/${sourceId}?${params}`, { method: "PATCH" });
        if (!res.ok) throw new Error(await getErrorMessage(res));

        showSuccess("Source updated successfully.");
        btn.textContent = "Saved!";
        setTimeout(() => { window.location.href = "/sources"; }, 1000);
      } catch (e) {
        showError("Error: " + e.message);
        btn.disabled = false;
        btn.textContent = "Save changes";
      }
    });

    load();
  </script>
</Layout>