---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Icon from "../components/Icon.astro";
---

<Layout title="Panel">
  <Nav />
  <main id="main" class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">Panel</h1>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
          <h2 class="card-title text-sm uppercase tracking-wider text-base-content/60 gap-2">
            <Icon name="inbox" size={16} /> Entradas
          </h2>
          <div class="grid grid-cols-3 gap-3 mt-1">
            <a
              href="/sources"
              class="flex flex-col items-center gap-1 p-3 rounded-box hover:bg-base-200 transition-colors duration-150 cursor-pointer no-underline"
              title="Ver fuentes"
            >
              <span class="text-primary"><Icon name="database" size={20} /></span>
              <span class="text-2xl font-bold text-primary" id="stat-sources">—</span>
              <span class="text-xs uppercase tracking-wider text-base-content/60">Fuentes</span>
            </a>
            <a
              href="/seeds"
              class="flex flex-col items-center gap-1 p-3 rounded-box hover:bg-base-200 transition-colors duration-150 cursor-pointer no-underline"
              title="Ver semillas"
            >
              <span class="text-primary"><Icon name="sprout" size={20} /></span>
              <span class="text-2xl font-bold text-primary" id="stat-seeds">—</span>
              <span class="text-xs uppercase tracking-wider text-base-content/60">Semillas</span>
            </a>
            <a
              href="/ideas"
              class="flex flex-col items-center gap-1 p-3 rounded-box hover:bg-base-200 transition-colors duration-150 cursor-pointer no-underline"
              title="Ver ideas"
            >
              <span class="text-primary"><Icon name="lightbulb" size={20} /></span>
              <span class="text-2xl font-bold text-primary" id="stat-ideas">—</span>
              <span class="text-xs uppercase tracking-wider text-base-content/60">Ideas</span>
            </a>
          </div>
        </div>
      </section>
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
          <h2 class="card-title text-sm uppercase tracking-wider text-base-content/60 gap-2">
            <Icon name="send" size={16} /> Salidas
          </h2>
          <div class="grid grid-cols-2 gap-3 mt-1">
            <a
              href="/drafts?status=draft"
              class="flex flex-col items-center gap-1 p-3 rounded-box hover:bg-base-200 transition-colors duration-150 cursor-pointer no-underline"
              title="Ver borradores pendientes"
            >
              <span class="text-primary"><Icon name="file-text" size={20} /></span>
              <span class="text-2xl font-bold text-primary" id="stat-drafts">—</span>
              <span class="text-xs uppercase tracking-wider text-base-content/60">Pendientes</span>
            </a>
            <a
              href="/drafts?status=published"
              class="flex flex-col items-center gap-1 p-3 rounded-box hover:bg-base-200 transition-colors duration-150 cursor-pointer no-underline"
              title="Ver publicados"
            >
              <span class="text-primary"><Icon name="check-circle" size={20} /></span>
              <span class="text-2xl font-bold text-primary" id="stat-published">—</span>
              <span class="text-xs uppercase tracking-wider text-base-content/60">Publicados</span>
            </a>
          </div>
        </div>
      </section>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
          <h2 class="card-title text-sm uppercase tracking-wider text-base-content/60 gap-2">
            <Icon name="sprout" size={16} /> Semillas recientes
          </h2>
          <div id="recent-seeds">
            <span class="loading loading-spinner loading-sm"></span>
            <span class="text-sm text-base-content/60">Cargando…</span>
          </div>
        </div>
      </section>
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
          <h2 class="card-title text-sm uppercase tracking-wider text-base-content/60 gap-2">
            <Icon name="file-text" size={16} /> Borradores recientes
          </h2>
          <div id="recent-drafts">
            <span class="loading loading-spinner loading-sm"></span>
            <span class="text-sm text-base-content/60">Cargando…</span>
          </div>
        </div>
      </section>
    </div>

    <section class="card bg-base-100 border border-base-300 shadow-sm mt-6">
      <div class="card-body p-5">
        <div class="flex items-center justify-between gap-2 flex-wrap">
          <h2 class="card-title text-sm uppercase tracking-wider text-base-content/60 gap-2">
            <Icon name="calendar" size={16} /> Borradores programados
          </h2>
          <button
            class="btn btn-sm btn-outline gap-1.5"
            id="btn-run-scheduler"
            title="Publica los borradores programados cuya fecha ya ha llegado"
          >
            <Icon name="play" size={14} /> Ejecutar planificador
          </button>
        </div>
        <div id="scheduled-drafts">
          <span class="loading loading-spinner loading-sm"></span>
          <span class="text-sm text-base-content/60">Cargando…</span>
        </div>
      </div>
    </section>
  </main>

  <script>
    import { icon } from "~/scripts/icons";
    import { byId, esc } from "~/scripts/dom";
    import type { Draft, Idea, ScheduledDraft, Seed, Source } from "~/scripts/types";

    const API = "http://localhost:8000/api";

    async function load() {
      const [sources, seeds, ideas, drafts, scheduled] = await Promise.all([
        fetch(`${API}/sources`).then((r) => r.json() as Promise<Source[]>),
        fetch(`${API}/seeds`).then((r) => r.json() as Promise<Seed[]>),
        fetch(`${API}/ideas`).then((r) => r.json() as Promise<Idea[]>),
        fetch(`${API}/drafts`).then((r) => r.json() as Promise<Draft[]>),
        fetch(`${API}/drafts/scheduled`)
          .then((r) => r.json() as Promise<ScheduledDraft[]>)
          .catch(() => [] as ScheduledDraft[]),
      ]);

      const published = drafts.filter((d) => d.status === "published");
      const pending = drafts.filter((d) => d.status === "draft");

      byId("stat-sources").textContent = String(sources.length);
      byId("stat-seeds").textContent = String(seeds.length);
      byId("stat-ideas").textContent = String(ideas.length);
      byId("stat-drafts").textContent = String(pending.length);
      byId("stat-published").textContent = String(published.length);

      const recentSeeds = seeds.slice(-5).reverse();
      byId("recent-seeds").innerHTML = recentSeeds.length
        ? `<div class="divide-y divide-base-200">${recentSeeds
            .map(
              (s) => `
            <a href="/seeds" class="flex items-center justify-between gap-3 py-3 px-1 no-underline hover:bg-base-200 -mx-1 px-3 rounded-lg transition-colors duration-150" title="${esc(s.title)}">
              <div class="min-w-0">
                <div class="font-semibold text-sm truncate">${esc(s.title)}</div>
                <div class="text-xs text-base-content/60">${s.created_at ? new Date(s.created_at).toLocaleDateString() : ""}</div>
              </div>
              <span class="badge badge-sm badge-soft ${s.status === "pending" ? "badge-warning" : s.status === "used" ? "badge-success" : s.status === "approved" ? "badge-info" : "badge-error"}">${esc(s.status)}</span>
            </a>`
            )
            .join("")}</div>`
        : '<div class="alert bg-base-200 text-sm">Aún no hay semillas.</div>';

      const recentDrafts = drafts.slice(-5).reverse();
      byId("recent-drafts").innerHTML = recentDrafts.length
        ? `<div class="divide-y divide-base-200">${recentDrafts
            .map((d) => {
              const preview = d.content
                ? d.content.substring(0, 80) + (d.content.length > 80 ? "…" : "")
                : "(vacío)";
              return `
            <a href="/drafts" class="flex items-center justify-between gap-3 py-3 px-1 no-underline hover:bg-base-200 -mx-1 px-3 rounded-lg transition-colors duration-150" title="${esc(preview)}">
              <div class="min-w-0">
                <div class="font-semibold text-sm truncate">${esc(preview)}</div>
                <div class="text-xs text-base-content/60">${d.created_at ? new Date(d.created_at).toLocaleDateString() : ""}</div>
              </div>
              <span class="badge badge-sm badge-soft ${d.status === "draft" ? "badge-warning" : d.status === "approved" ? "badge-info" : d.status === "published" ? "badge-success" : "badge-error"}">${esc(d.status)}</span>
            </a>`;
            })
            .join("")}</div>`
        : '<div class="alert bg-base-200 text-sm">Aún no hay borradores.</div>';

      const sortedScheduled = scheduled
        .slice()
        .sort((a, b) => new Date(a.scheduled_at || 0).getTime() - new Date(b.scheduled_at || 0).getTime());
      byId("scheduled-drafts").innerHTML = sortedScheduled.length
        ? `<div class="divide-y divide-base-200">${sortedScheduled
            .map((d) => {
              const preview = d.content
                ? d.content.substring(0, 60) + (d.content.length > 60 ? "…" : "")
                : "(vacío)";
              const due = new Date(d.scheduled_at || 0) <= new Date();
              return `
            <a href="/drafts/edit?id=${d.id}" class="flex items-center justify-between gap-3 py-3 px-1 no-underline hover:bg-base-200 -mx-1 px-3 rounded-lg transition-colors duration-150" title="${esc(preview)}">
              <div class="min-w-0">
                <div class="font-semibold text-sm truncate">${esc(preview)}</div>
                <div class="text-xs text-base-content/60 capitalize">${esc(d.platform)}</div>
              </div>
              <span class="badge badge-sm badge-soft ${due ? "badge-warning" : "badge-secondary"} whitespace-nowrap" title="${esc(d.scheduled_at)}">${new Date(d.scheduled_at || 0).toLocaleString()}</span>
            </a>`;
            })
            .join("")}</div>`
        : '<div class="alert bg-base-200 text-sm">No hay borradores programados.</div>';
    }

    byId("btn-run-scheduler").addEventListener("click", async () => {
      const btn = byId<HTMLButtonElement>("btn-run-scheduler");
      btn.disabled = true;
      btn.textContent = "Ejecutando…";
      try {
        const res = await fetch(`${API}/scheduler/run`, { method: "POST" });
        if (!res.ok) throw new Error("Scheduler failed");
        await load();
      } catch {
      } finally {
        btn.disabled = false;
        btn.innerHTML = `${icon("play", 14)} Ejecutar planificador`;
      }
    });

    load();
  </script>
</Layout>
